{
  "autoindent": true,
  "backup": true,
  "clipboard": "external",
  "colorscheme": "installations-configurations",
  "cursorline": true,
  "diff": true,
  "diffgutter": true,
  "eofnewline": true,
  "hlsearch": true,
  "hltaberrors": true,
  "hltrailingws": true,
  "ignorecase": true,
  "incsearch": true,
  "matchbrace": true,
  "matchbraceleft": true,
  "mouse": true,
  "pluginchannels": [
    "https://raw.githubusercontent.com/micro-editor/plugin-channel/master/channel.json"
  ],
  "ruler": true,
  "savehistory": true,
  "saveundo": true,
  "scrollmargin": 4,
  "smartpaste": true,
  "softwrap": false,
  "splitbottom": true,
  "splitright": true,
  "status": true,
  "statusline": true,
  "syntax": true,
  "tabsize": 4,
  "tabstospaces": true,
  "truecolor": "auto"
}
