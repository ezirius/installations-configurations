#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/../../../lib/shell/shared/common.sh"
source "$SCRIPT_DIR/../../../lib/shell/shared/homebrew.sh"

if is_help_flag "${1-}"; then
  show_help "Usage: $(basename "$0") {start|stop|restart|reload|status}

Manage the Caddy background service.

Actions:
  start    Start Caddy, or reload it when already running.
  stop     Stop the Caddy service.
  restart  Restart the Caddy service.
  reload   Reload the deployed Caddy config without downtime.
  status   Show the current Caddy service status."
fi

if [[ $# -ne 1 ]]; then
  usage_error "$(basename "$0") takes exactly 1 argument: {start|stop|restart|reload|status}"
fi

ACTION="$1"
BREW_PREFIX=""
TARGET_CONFIG=""
CADDY_SERVICE_NAME=""

load_caddy_config() {
  source_shell_config "$(preferred_scoped_config_path "config/caddy" "macos" "caddy-settings" "conf")"
}

validate_runtime_config() {
  caddy validate --config "$TARGET_CONFIG" --adapter caddyfile >/dev/null
}

resolve_listener_port() {
  local address_line

  address_line="$(grep -E '^[[:space:]]*[^#[:space:]\{]*:[^[:space:]]*[[:space:]]*\{' "$TARGET_CONFIG" 2>/dev/null | head -n 1 || true)"
  address_line="${address_line#${address_line%%[![:space:]]*}}"
  address_line="${address_line%%[[:space:]]*\{}"

  if [[ "$address_line" != *:* ]]; then
    return 1
  fi

  printf '%s\n' "${address_line##*:}"
}

port_in_use() {
  local port

  port="$(resolve_listener_port)"

  if [[ -z "$port" || ! $port =~ ^[0-9]+$ ]]; then
    return 1
  fi

  command -v lsof >/dev/null 2>&1 && lsof -nP -iTCP:"$port" -sTCP:LISTEN >/dev/null 2>&1
}

service_start_failed() {
  fail "Caddy service failed to start. Validate the managed Caddyfile with 'caddy validate --config $TARGET_CONFIG --adapter caddyfile', check 'brew services info $CADDY_SERVICE_NAME', and inspect whether the configured listener port is already in use."
}

service_started() {
  brew services list | grep -Eq "^$CADDY_SERVICE_NAME[[:space:]]+started([[:space:]]|$)"
}

case "$ACTION" in
  start|stop|restart|reload|status) ;;
  *)
    usage_error "$(basename "$0") takes exactly 1 argument: {start|stop|restart|reload|status}"
    ;;
esac

require_macos
require_homebrew
require_clt
require_command caddy "Run scripts/brew/macos/brew-install before managing the Caddy service"
load_caddy_config

BREW_PREFIX="$(brew --prefix)"
TARGET_CONFIG="$BREW_PREFIX/$CADDY_RUNTIME_RELATIVE_PATH"

[[ -f "$TARGET_CONFIG" ]] || fail "Managed Caddyfile not found: $TARGET_CONFIG; run scripts/caddy/macos/caddy-configure first"

case "$ACTION" in
  stop|status) ;;
  *) validate_runtime_config ;;
esac

case "$ACTION" in
  start)
    if service_started; then
      echo "==> Reloading the running Caddy background service"
      caddy reload --config "$TARGET_CONFIG" --adapter caddyfile
    else
      if port_in_use; then
        fail "The managed Caddy listener port is already in use. Stop the conflicting listener or update the shared Caddyfile before starting the service."
      fi

      echo "==> Starting Caddy background service"
      if ! brew services start "$CADDY_SERVICE_NAME"; then
        service_start_failed
      fi
    fi
    ;;
  stop)
    echo "==> Stopping Caddy background service"
    brew services stop "$CADDY_SERVICE_NAME"
    ;;
  restart)
    echo "==> Restarting Caddy background service"
    brew services restart "$CADDY_SERVICE_NAME"
    ;;
  reload)
    if ! service_started; then
      fail "Caddy service is not running; run scripts/caddy/macos/caddy-service start first"
    fi

    echo "==> Reloading Caddy without downtime"
    caddy reload --config "$TARGET_CONFIG" --adapter caddyfile
    ;;
  status)
    echo "==> Showing Caddy service status"
    brew services info "$CADDY_SERVICE_NAME"
    ;;
esac
