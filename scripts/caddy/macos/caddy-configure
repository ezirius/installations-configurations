#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/../../../lib/shell/shared/common.sh"
source "$SCRIPT_DIR/../../../lib/shell/shared/homebrew.sh"

if is_help_flag "${1-}"; then
  show_help "Usage: $(basename "$0") [caddyfile-path]

Validate and deploy the managed Caddyfile into Homebrew's runtime config path.

Arguments:
  [caddyfile-path]  Optional explicit Caddyfile override."
fi

if [[ $# -gt 1 ]]; then
  usage_error "$(basename "$0") takes at most 1 argument: [caddyfile-path]"
fi

SOURCE_CONFIG="${1:-}"
BREW_PREFIX=""
TARGET_CONFIG=""
TEMP_FILE=""
PYTHON3_COMMAND=""

load_caddy_config() {
  source_shell_config "$(preferred_scoped_config_path "config/caddy" "macos" "caddy-settings" "conf")"
}

cleanup() {
  rm -f "$TEMP_FILE"
}

trap cleanup EXIT

render_caddyfile() {
  local output_path="$1"
  shift

  mkdir -p "$(dirname "$output_path")"
  TEMP_FILE="$(mktemp)"
  "$PYTHON3_COMMAND" - "$TEMP_FILE" "$@" <<'PY'
from pathlib import Path
import sys

destination = Path(sys.argv[1])
parts = []
for source_path in sys.argv[2:]:
    parts.append(Path(source_path).read_text().rstrip())

destination.write_text("\n\n".join(part for part in parts if part) + "\n")
PY

  mv "$TEMP_FILE" "$output_path"
  TEMP_FILE=""
}

deploy_rendered_caddyfile() {
  local rendered_path="$1"
  local target_path="$2"
  local change_name="Created"

  mkdir -p "$(dirname "$target_path")"

  if [[ -f "$target_path" ]] && cmp -s "$rendered_path" "$target_path"; then
    return 0
  fi

  if [[ -f "$target_path" ]]; then
    change_name="Updated"
  fi

  cp "$rendered_path" "$target_path"
  log_change "Configuration" "Caddyfile" "$change_name" "$target_path" "Deployed managed Caddy reverse proxy config"
}

require_macos
require_homebrew
require_clt
require_command cmp
require_command caddy "Run scripts/brew/macos/brew-install before configuring Caddy"
initialize_change_log "scripts/caddy/macos/caddy-configure"
PYTHON3_COMMAND="$(preferred_python3_command)"
load_caddy_config

BREW_PREFIX="$(brew --prefix)"
TARGET_CONFIG="$BREW_PREFIX/$CADDY_RUNTIME_RELATIVE_PATH"

echo "==> Checking Caddy config source"
if [[ -n "$SOURCE_CONFIG" ]]; then
  [[ -f "$SOURCE_CONFIG" ]] || fail "Caddyfile not found: $SOURCE_CONFIG"
  render_caddyfile "$TARGET_CONFIG.rendered" "$SOURCE_CONFIG"
else
  SOURCE_CONFIG="$(preferred_scoped_config_path "config/caddy" "macos" "caddy-runtime" "Caddyfile")"
  [[ -f "$SOURCE_CONFIG" ]] || fail "Managed Caddyfile not found: $SOURCE_CONFIG"
  render_caddyfile "$TARGET_CONFIG.rendered" "$SOURCE_CONFIG"
fi

echo "==> Validating managed Caddyfile"
caddy validate --config "$TARGET_CONFIG.rendered" --adapter caddyfile >/dev/null

echo "==> Deploying managed Caddyfile"
deploy_rendered_caddyfile "$TARGET_CONFIG.rendered" "$TARGET_CONFIG"

echo "==> Caddy config is ready"
