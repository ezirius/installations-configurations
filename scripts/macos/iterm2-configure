#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/../../lib/shell/common.sh"

if [[ $# -gt 1 ]]; then
  usage_error "$(basename "$0") takes at most 1 argument: [config-path]"
fi

ROOT="$(repo_root)"
CONFIG_FILE="${1:-$ROOT/config/iterm2/defaults.conf}"
ITERM_DOMAIN="com.googlecode.iterm2"
ITERM_PREFS_PATH="$HOME/Library/Preferences/${ITERM_DOMAIN}.plist"

normalize_bool() {
  case "$1" in
    true|TRUE|True|1|yes|YES|on|ON) printf '%s\n' 'true' ;;
    false|FALSE|False|0|no|NO|off|OFF) printf '%s\n' 'false' ;;
    *) fail "Unsupported boolean value: $1" ;;
  esac
}

read_current_bool() {
  local key="$1"
  local raw_value

  raw_value="$(defaults read "$ITERM_DOMAIN" "$key" 2>/dev/null || true)"
  [[ -n "$raw_value" ]] || return 0

  normalize_bool "$raw_value"
}

apply_bool_setting() {
  local key="$1"
  local requested_value="$2"
  local desired_value
  local current_value
  local change_name
  local verified_value

  desired_value="$(normalize_bool "$requested_value")"
  current_value="$(read_current_bool "$key")"

  if [[ "$current_value" == "$desired_value" ]]; then
    return 0
  fi

  if [[ -n "$current_value" ]]; then
    change_name="Updated"
  else
    change_name="Created"
  fi

  defaults write "$ITERM_DOMAIN" "$key" -bool "$desired_value"
  verified_value="$(read_current_bool "$key")"
  [[ "$verified_value" == "$desired_value" ]] || fail "Failed to verify iTerm2 setting $key"

  log_change "Configuration" "iTerm2 $key" "$change_name" "$ITERM_PREFS_PATH" "Set $key=$desired_value"
}

require_macos
require_command defaults
initialize_change_log "scripts/macos/iterm2-configure"

echo "==> Checking iTerm2 config source"
[[ -f "$CONFIG_FILE" ]] || fail "iTerm2 config not found: $CONFIG_FILE"

echo "==> Applying managed iTerm2 preferences"
while IFS='|' read -r value_type key value; do
  [[ -n "$value_type" ]] || continue
  [[ "$value_type" == \#* ]] && continue
  [[ -n "$key" ]] || fail "Missing iTerm2 config key in $CONFIG_FILE"
  [[ -n "$value" ]] || fail "Missing iTerm2 config value for $key in $CONFIG_FILE"

  case "$value_type" in
    bool)
      apply_bool_setting "$key" "$value"
      ;;
    *)
      fail "Unsupported iTerm2 config type '$value_type' in $CONFIG_FILE"
      ;;
  esac
done < "$CONFIG_FILE"

echo "==> iTerm2 preferences are ready"
