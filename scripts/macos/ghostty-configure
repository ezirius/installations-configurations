#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/../../lib/shell/common.sh"

if [[ $# -gt 1 ]]; then
  usage_error "$(basename "$0") takes at most 1 argument: [config-dir]"
fi

ROOT="$(repo_root)"
SOURCE_CONFIG="$ROOT/config/ghostty/installations-configurations.ghostty"
TARGET_CONFIG_DIR="${1:-${XDG_CONFIG_HOME:-$HOME/.config}/ghostty}"
TARGET_CONFIG="$TARGET_CONFIG_DIR/config.ghostty"
TARGET_INCLUDE="$TARGET_CONFIG_DIR/installations-configurations.ghostty"
INCLUDE_DIRECTIVE='config-file = "installations-configurations.ghostty"'
NU_PATH=""
TEMP_FILE=""
PYTHON3_COMMAND=""

cleanup() {
  rm -f "$TEMP_FILE"
}

trap cleanup EXIT

write_rendered_config() {
  local source_path="$1"
  local target_path="$2"
  local nu_path="$3"
  local change_name="Created"

  TEMP_FILE="$(mktemp)"
  "$PYTHON3_COMMAND" - "$source_path" "$TEMP_FILE" "$nu_path" <<'PY'
from pathlib import Path
import sys

source = Path(sys.argv[1]).read_text()
destination = Path(sys.argv[2])
nu_path = sys.argv[3]

destination.write_text(source.replace("__NU_PATH__", nu_path))
PY

  mkdir -p "$(dirname "$target_path")"

  if [[ -f "$target_path" ]] && cmp -s "$TEMP_FILE" "$target_path"; then
    return 0
  fi

  if [[ -f "$target_path" ]]; then
    change_name="Updated"
  fi

  mv "$TEMP_FILE" "$target_path"
  TEMP_FILE=""
  log_change "Configuration" "Ghostty config" "$change_name" "$target_path" "Configured Ghostty to launch Nushell with the managed dark theme"
}

ensure_include_directive() {
  local target_path="$1"
  local include_directive="$2"
  local change_name="Created"

  mkdir -p "$(dirname "$target_path")"

  if [[ ! -f "$target_path" ]]; then
    printf '%s\n' "$include_directive" > "$target_path"
    log_change "Configuration" "Ghostty config include" "$change_name" "$target_path" "Added the managed Ghostty include to the primary config"
    return 0
  fi

  if grep -Fqx "$include_directive" "$target_path"; then
    return 0
  fi

  printf '\n%s\n' "$include_directive" >> "$target_path"
  log_change "Configuration" "Ghostty config include" "Updated" "$target_path" "Added the managed Ghostty include to the primary config"
}

require_macos
require_homebrew
require_clt
require_command cmp
initialize_change_log "scripts/macos/ghostty-configure"
PYTHON3_COMMAND="$(preferred_python3_command)"

echo "==> Checking Ghostty config source"
[[ -f "$SOURCE_CONFIG" ]] || fail "Ghostty config not found: $SOURCE_CONFIG"

NU_PATH="$(homebrew_root_path)/bin/nu"
[[ -x "$NU_PATH" ]] || fail "nushell is not installed at $NU_PATH; run scripts/macos/brewfile-install first"

echo "==> Deploying Ghostty config"
write_rendered_config "$SOURCE_CONFIG" "$TARGET_INCLUDE" "$NU_PATH"
ensure_include_directive "$TARGET_CONFIG" "$INCLUDE_DIRECTIVE"

echo "==> Ghostty is ready"
