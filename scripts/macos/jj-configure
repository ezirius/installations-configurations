#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/../../lib/shell/common.sh"

if [[ $# -gt 1 ]]; then
  usage_error "$(basename "$0") takes at most 1 argument: [config-path]"
fi

ROOT="$(repo_root)"
SOURCE_CONFIG="$ROOT/config/jj/config.toml"
TARGET_CONFIG="${1:-${XDG_CONFIG_HOME:-$HOME/.config}/jj/config.toml}"
JJ_USER_NAME=""
JJ_USER_EMAIL=""
TEMP_FILE=""
PYTHON3_COMMAND=""

cleanup() {
  rm -f "$TEMP_FILE"
}

trap cleanup EXIT

render_config() {
  local source_path="$1"
  local output_path="$2"
  local user_name="$3"
  local user_email="$4"
  local change_name="Created"

  TEMP_FILE="$(mktemp)"
  "$PYTHON3_COMMAND" - "$source_path" "$TEMP_FILE" "$user_name" "$user_email" <<'PY'
from pathlib import Path
import sys

source = Path(sys.argv[1]).read_text()
destination = Path(sys.argv[2])
destination.write_text(
    source.replace("__JJ_USER_NAME__", sys.argv[3]).replace("__JJ_USER_EMAIL__", sys.argv[4])
)
PY

  mkdir -p "$(dirname "$output_path")"

  if [[ -f "$output_path" ]] && cmp -s "$TEMP_FILE" "$output_path"; then
    return 0
  fi

  if [[ -f "$output_path" ]]; then
    change_name="Updated"
  fi

  mv "$TEMP_FILE" "$output_path"
  TEMP_FILE=""
  log_change "Configuration" "jj config" "$change_name" "$output_path" "Configured jj identity defaults"
}

require_macos
require_homebrew
require_clt
require_command cmp
require_command git "Install Git before running this script"
require_command jj "Run scripts/macos/brew-install before configuring jj"
require_git_repo_path "$ROOT"
initialize_change_log "scripts/macos/jj-configure"
PYTHON3_COMMAND="$(preferred_python3_command)"

echo "==> Checking jj config source"
[[ -f "$SOURCE_CONFIG" ]] || fail "jj config not found: $SOURCE_CONFIG"

JJ_USER_NAME="$(git -C "$ROOT" config user.name || true)"
JJ_USER_EMAIL="$(git -C "$ROOT" config user.email || true)"

[[ -n "$JJ_USER_NAME" ]] || fail "Git user.name is not set for this repository; set it before configuring jj"
[[ -n "$JJ_USER_EMAIL" ]] || fail "Git user.email is not set for this repository; set it before configuring jj"

echo "==> Deploying jj config"
render_config "$SOURCE_CONFIG" "$TARGET_CONFIG" "$JJ_USER_NAME" "$JJ_USER_EMAIL"

echo "==> jj is ready"
