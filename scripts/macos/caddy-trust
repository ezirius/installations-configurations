#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/../../lib/shell/common.sh"

if is_help_flag "${1-}"; then
  show_help "Usage: $(basename "$0")

Trust the local Caddy CA used by the managed HTTPS reverse proxy.

Notes:
  - Safe to rerun.
  - Requires the managed Caddyfile to already be deployed."
fi

if [[ $# -ne 0 ]]; then
  usage_error "$(basename "$0") takes no arguments"
fi

BREW_PREFIX=""
TARGET_CONFIG=""
TRUSTED_KEYCHAIN=""

load_caddy_config() {
  source_shell_config "$(shared_platform_config_path "config/caddy" "conf")"
}

find_trusted_keychain() {
  local keychain

  for keychain in "${CADDY_TRUST_KEYCHAINS[@]}"; do
    if security find-certificate -c "$CADDY_TRUST_CERT_NAME" "$keychain" >/dev/null 2>&1; then
      printf '%s\n' "$keychain"
      return 0
    fi
  done

  return 1
}

require_macos
require_homebrew
require_clt
require_command caddy "Run scripts/macos/brew-install before trusting the Caddy local CA"
require_command security
initialize_change_log "scripts/macos/caddy-trust"
load_caddy_config

BREW_PREFIX="$(brew --prefix)"
TARGET_CONFIG="$BREW_PREFIX/$CADDY_RUNTIME_RELATIVE_PATH"

[[ -f "$TARGET_CONFIG" ]] || fail "Managed Caddyfile not found: $TARGET_CONFIG; run scripts/macos/caddy-configure first"

echo "==> Trusting the Caddy local CA"
caddy trust --config "$TARGET_CONFIG" --adapter caddyfile >/dev/null

TRUSTED_KEYCHAIN="$(find_trusted_keychain || true)"
[[ -n "$TRUSTED_KEYCHAIN" ]] || fail "Caddy trust completed without a detectable trusted local CA certificate"

log_change "Configuration" "Caddy local CA" "Trusted" "$TRUSTED_KEYCHAIN" "Trusted the managed Caddy local CA for local HTTPS"

echo "==> Caddy local CA is trusted"
