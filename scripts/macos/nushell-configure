#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/../../lib/shell/common.sh"

if [[ $# -gt 1 ]]; then
  usage_error "$(basename "$0") takes at most 1 argument: [config-dir]"
fi

ROOT="$(repo_root)"
SOURCE_DIR="$ROOT/config/nushell"
TARGET_DIR="${1:-${XDG_CONFIG_HOME:-$HOME/.config}/nushell}"
AUTOLOAD_DIR="$TARGET_DIR/autoload"
COMPAT_PATH="${NUSHELL_MACOS_COMPAT_PATH:-$HOME/Library/Application Support/nushell}"
TEMP_FILE=""
PYTHON3_COMMAND=""

cleanup() {
  rm -f "$TEMP_FILE"
}

trap cleanup EXIT

copy_rendered_file() {
  local source_path="$1"
  local target_path="$2"
  local item_name="$3"
  local details="$4"
  local change_name="Created"

  TEMP_FILE="$(mktemp)"
  "$PYTHON3_COMMAND" - "$source_path" "$TEMP_FILE" "$TARGET_DIR" <<'PY'
from pathlib import Path
import sys

source = Path(sys.argv[1]).read_text()
destination = Path(sys.argv[2])
target_dir = sys.argv[3]

destination.write_text(source.replace("__NUSHELL_DIR__", target_dir))
PY

  mkdir -p "$(dirname "$target_path")"

  if [[ -f "$target_path" ]] && cmp -s "$TEMP_FILE" "$target_path"; then
    return 0
  fi

  if [[ -f "$target_path" ]]; then
    change_name="Updated"
  fi

  mv "$TEMP_FILE" "$target_path"
  TEMP_FILE=""
  log_change "Configuration" "$item_name" "$change_name" "$target_path" "$details"
}

generate_file() {
  local target_path="$1"
  local item_name="$2"
  local details="$3"
  shift 3
  local change_name="Created"

  TEMP_FILE="$(mktemp)"
  "$@" > "$TEMP_FILE"

  mkdir -p "$(dirname "$target_path")"

  if [[ -f "$target_path" ]] && cmp -s "$TEMP_FILE" "$target_path"; then
    return 0
  fi

  if [[ -f "$target_path" ]]; then
    change_name="Updated"
  fi

  mv "$TEMP_FILE" "$target_path"
  TEMP_FILE=""
  log_change "Configuration" "$item_name" "$change_name" "$target_path" "$details"
}

ensure_compat_symlink() {
  local target_dir="$1"
  local compat_path="$2"
  local current_target=""
  local change_name="Created"

  mkdir -p "$(dirname "$compat_path")"

  if [[ -L "$compat_path" ]]; then
    current_target="$(readlink "$compat_path")"
    if [[ "$current_target" == "$target_dir" ]]; then
      return 0
    fi

    rm "$compat_path"
    change_name="Updated"
  elif [[ -e "$compat_path" ]]; then
    fail "Nushell compatibility path already exists and is not a symlink: $compat_path"
  fi

  ln -s "$target_dir" "$compat_path"
  log_change "Configuration" "Nushell compatibility symlink" "$change_name" "$compat_path" "Linked macOS Application Support to the managed ~/.config/nushell tree"
}

require_macos
require_homebrew
require_clt
require_command cmp
require_command atuin "Run scripts/macos/brew-install before configuring Nushell"
require_command starship "Run scripts/macos/brew-install before configuring Nushell"
require_command zoxide "Run scripts/macos/brew-install before configuring Nushell"
require_command jj "Run scripts/macos/brew-install before configuring Nushell"
initialize_change_log "scripts/macos/nushell-configure"
PYTHON3_COMMAND="$(preferred_python3_command)"

echo "==> Checking Nushell config sources"
[[ -d "$SOURCE_DIR" ]] || fail "Nushell config directory not found: $SOURCE_DIR"

echo "==> Deploying managed Nushell config"
copy_rendered_file "$SOURCE_DIR/installations-configurations.nu" "$AUTOLOAD_DIR/installations-configurations.nu" "Nushell tooling" "Configured managed Nushell tooling integration"

echo "==> Generating Nushell tool integrations"
generate_file "$TARGET_DIR/atuin.nu" "atuin Nushell integration" "Generated Nushell integration for atuin" atuin init nu
generate_file "$TARGET_DIR/starship.nu" "starship Nushell integration" "Generated Nushell integration for starship" starship init nu
generate_file "$TARGET_DIR/zoxide.nu" "zoxide Nushell integration" "Generated Nushell integration for zoxide" zoxide init nushell
generate_file "$TARGET_DIR/completions-jj.nu" "jj Nushell completions" "Generated Nushell completions for jj" jj util completion nushell

echo "==> Creating macOS compatibility symlink"
ensure_compat_symlink "$TARGET_DIR" "$COMPAT_PATH"

echo "==> Nushell is ready"
