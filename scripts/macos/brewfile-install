#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/../../lib/shell/common.sh"

ROOT="$(repo_root)"
BREWFILE="${1:-$ROOT/config/brew/Brewfile}"
BREW_PREFIX=""
ENTRIES_FILE=""
BEFORE_FILE=""
AFTER_FILE=""
CHANGES_FILE=""

require_macos
require_homebrew
require_clt
require_command python3 "Install Python 3 before running this script"
initialize_change_log "scripts/macos/brewfile-install"

cleanup() {
  rm -f "$ENTRIES_FILE" "$BEFORE_FILE" "$AFTER_FILE" "$CHANGES_FILE"
}

trap cleanup EXIT

snapshot_brewfile_state() {
  local output_file="$1"
  local entry_type
  local entry_name
  local version_line

  : > "$output_file"

  while IFS='|' read -r entry_type entry_name; do
    version_line=""

    if [[ "$entry_type" == "brew" ]]; then
      version_line="$(brew list --versions "$entry_name" 2>/dev/null || true)"
    else
      version_line="$(brew list --cask --versions "$entry_name" 2>/dev/null || true)"
    fi

    if [[ -n "$version_line" ]]; then
      printf '%s|%s|installed|%s\n' "$entry_type" "$entry_name" "$version_line" >> "$output_file"
    else
      printf '%s|%s|missing|\n' "$entry_type" "$entry_name" >> "$output_file"
    fi
  done < "$ENTRIES_FILE"
}

echo "==> Checking Brewfile"
if [[ ! -f "$BREWFILE" ]]; then
  fail "Brewfile not found: $BREWFILE"
fi

BREW_PREFIX="$(brew --prefix)"
ENTRIES_FILE="$(mktemp)"
BEFORE_FILE="$(mktemp)"
AFTER_FILE="$(mktemp)"
CHANGES_FILE="$(mktemp)"

python3 - "$BREWFILE" <<'PY' > "$ENTRIES_FILE"
import pathlib
import re
import sys

brewfile = pathlib.Path(sys.argv[1]).read_text().splitlines()
pattern = re.compile(r'^(brew|cask)\s+"([^"]+)"')

for line in brewfile:
    match = pattern.match(line.strip())
    if match:
        print(f"{match.group(1)}|{match.group(2)}")
PY

snapshot_brewfile_state "$BEFORE_FILE"

echo "==> Checking Brewfile state"
if brew bundle check --file="$BREWFILE"; then
  echo "Brewfile already satisfied"
else
  echo "==> Applying Brewfile"
  brew bundle install --file="$BREWFILE"

  snapshot_brewfile_state "$AFTER_FILE"
  python3 - "$BEFORE_FILE" "$AFTER_FILE" <<'PY' > "$CHANGES_FILE"
from pathlib import Path
import sys

def read_state(path):
    rows = {}
    for line in Path(path).read_text().splitlines():
        entry_type, name, state, version = line.split("|", 3)
        rows[(entry_type, name)] = {"state": state, "version": version}
    return rows

before = read_state(sys.argv[1])
after = read_state(sys.argv[2])

for (entry_type, name), after_data in after.items():
    before_data = before[(entry_type, name)]
    if before_data["state"] == "missing" and after_data["state"] == "installed":
        print(f"{entry_type}|{name}|Installed")
    elif before_data["state"] == "installed" and after_data["state"] == "installed" and before_data["version"] != after_data["version"]:
        print(f"{entry_type}|{name}|Upgraded")
PY

  while IFS='|' read -r entry_type entry_name change_name; do
    [[ -n "$entry_name" ]] || continue
    log_change "Installation" "$entry_name" "$change_name" "$BREW_PREFIX" "Managed by Brewfile"
  done < "$CHANGES_FILE"
fi

echo "==> Brewfile applied successfully"
