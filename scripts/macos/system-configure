#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/../../lib/shell/common.sh"

if is_help_flag "${1-}"; then
  show_help "Usage: $(basename "$0")

Apply the managed macOS system settings.

Notes:
  - Loads the shared macOS system config and any matching host-specific override.
  - Requires sudo for the managed pmset change."
fi

if [[ $# -ne 0 ]]; then
  usage_error "$(basename "$0") takes no arguments"
fi

SYSTEM_CONFIG_SHARED="$(shared_platform_config_path "config/system" "conf")"
SYSTEM_CONFIG_HOST="$(host_platform_config_path "config/system" "conf")"
DOCK_AUTO_HIDE=""
DOCK_REORDER_SPACES_BY_RECENT_USE=""
AC_POWER_SYSTEM_SLEEP_MINUTES=""
DOCK_CHANGED="0"
DOCK_DOMAIN="com.apple.dock"
DOCK_AUTO_HIDE_KEY="autohide"
DOCK_REORDER_SPACES_BY_RECENT_USE_KEY="mru-spaces"

load_system_config() {
  local config_path

  for config_path in "$SYSTEM_CONFIG_SHARED" "$SYSTEM_CONFIG_HOST"; do
    if [[ -f "$config_path" ]]; then
      # shellcheck disable=SC1090
      source "$config_path"
    fi
  done
}

bool_to_defaults_value() {
  case "$1" in
    true) printf '%s\n' '1' ;;
    false) printf '%s\n' '0' ;;
    *) fail "Invalid boolean value: $1" ;;
  esac
}

set_dock_bool() {
  local key_name="$1"
  local desired_value="$2"
  local item_name="$3"
  local current_value=""

  current_value="$(defaults read "$DOCK_DOMAIN" "$key_name" 2>/dev/null || printf '0')"
  desired_value="$(bool_to_defaults_value "$desired_value")"

  if [[ "$current_value" == "$desired_value" ]]; then
    return 0
  fi

  defaults write "$DOCK_DOMAIN" "$key_name" -bool "$desired_value"
  DOCK_CHANGED="1"
}

mac_is_portable() {
  pmset -g batt 2>/dev/null | grep -q 'InternalBattery'
}

current_pmset_sleep_setting() {
  local power_section="$1"

  pmset -g custom | awk -v section="$power_section" '
    $0 == section":" { in_section = 1; next }
    /^[A-Za-z].*:$/ { in_section = 0 }
    in_section && $1 == "sleep" { print $2; exit }
  '
}

apply_pmset_sleep() {
  local desired_value="$1"
  local scope_flag="-a"
  local power_section="AC Power"
  local current_value=""

  if mac_is_portable; then
    scope_flag="-c"
  fi

  current_value="$(current_pmset_sleep_setting "$power_section" || true)"
  if [[ "$current_value" == "$desired_value" ]]; then
    return 0
  fi

  sudo pmset "$scope_flag" sleep "$desired_value"
}

require_macos
require_clt
require_command defaults
require_command grep
require_command pmset
require_command sudo

echo "==> Loading managed macOS system config"
[[ -f "$SYSTEM_CONFIG_SHARED" ]] || fail "Shared macOS system config not found: $SYSTEM_CONFIG_SHARED"
load_system_config

[[ -n "$DOCK_AUTO_HIDE" ]] || fail "DOCK_AUTO_HIDE is not set in the managed macOS system config"
[[ -n "$DOCK_REORDER_SPACES_BY_RECENT_USE" ]] || fail "DOCK_REORDER_SPACES_BY_RECENT_USE is not set in the managed macOS system config"
[[ -n "$AC_POWER_SYSTEM_SLEEP_MINUTES" ]] || fail "AC_POWER_SYSTEM_SLEEP_MINUTES is not set in the managed macOS system config"

echo "==> Applying Dock settings"
set_dock_bool "$DOCK_AUTO_HIDE_KEY" "$DOCK_AUTO_HIDE" "Dock auto-hide"
set_dock_bool "$DOCK_REORDER_SPACES_BY_RECENT_USE_KEY" "$DOCK_REORDER_SPACES_BY_RECENT_USE" "Dock recent-spaces reordering"

if [[ "$DOCK_CHANGED" == "1" ]]; then
  killall Dock >/dev/null 2>&1 || true
fi

echo "==> Applying power settings"
sudo -v
apply_pmset_sleep "$AC_POWER_SYSTEM_SLEEP_MINUTES"

echo "==> macOS system settings are ready"
