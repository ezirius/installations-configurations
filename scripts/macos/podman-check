#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/../../lib/shell/common.sh"

if [[ $# -ne 0 ]]; then
  usage_error "$(basename "$0") takes no arguments"
fi

require_macos
require_command podman "Install or update Podman first with scripts/macos/bootstrap or scripts/macos/brew-upgrade"

echo "==> podman version"
podman version
echo
echo "==> podman machine list"
podman machine list
echo
echo "==> podman info"
podman info
echo
echo "==> test container"
podman run --rm docker.io/library/alpine:latest echo "hello from podman"
