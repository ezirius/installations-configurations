#!/usr/bin/env bash
# Apply the managed macOS system settings.
#
# This script resolves layered macOS system config from:
# - configs/shared/system/system-shared-shared.conf
# - configs/shared/system/system-shared-<username>.conf
# - configs/shared/system/system-<host>-shared.conf
# - configs/shared/system/system-<host>-<username>.conf
# - configs/macos/system/system-shared-shared.conf
# - configs/macos/system/system-shared-<username>.conf
# - configs/macos/system/system-<host>-shared.conf
# - configs/macos/system/system-<host>-<username>.conf
#
# Matching files are loaded from least specific to most specific.
#
# The current managed settings are Dock auto-hide, Spaces ordering by recent
# use, AC power system sleep minutes, and hardened macOS SSH server access.

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/../../../libs/shared/shared/common.sh"

show_usage() {
  show_help "Usage: $(basename "$0") [-h|--help]

Apply the managed macOS system settings.

Notes:
  - Loads matching layered system config files in order.
  - Requires sudo for the managed pmset change."
}

require_macos() {
  [[ "$(detect_os)" == "macos" ]] || fail 'This script is for macOS only'
}

require_command() {
  local command_name="$1"

  command -v "$command_name" >/dev/null 2>&1 || fail "Required command is missing: $command_name"
}

contains_distinct_word() {
  local haystack="$1"
  local needle="$2"

  case " $haystack " in
    *" $needle "*) return 0 ;;
  esac

  return 1
}

contains_pub_file_name() {
  [[ "$1" == *.pub ]]
}

SYSTEM_CONFIGS=()

optional_system_setting_names() {
  printf '%s\n' \
    'DOCK_AUTO_HIDE' \
    'DOCK_REORDER_SPACES_BY_RECENT_USE' \
    'AC_POWER_SYSTEM_SLEEP_MINUTES' \
    'TIME_ZONE_AUTO_BY_LOCATION' \
    'TIME_ZONE' \
    'CLOCK_24_HOUR' \
    'SSH_REMOTE_LOGIN_ENABLED' \
    'SSHD_ALLOW_USERS' \
    'SSHD_LOGIN_KEY_FILES'
}

clear_optional_system_setting_values() {
  clear_config_values \
    'DOCK_AUTO_HIDE' \
    'DOCK_REORDER_SPACES_BY_RECENT_USE' \
    'AC_POWER_SYSTEM_SLEEP_MINUTES' \
    'TIME_ZONE_AUTO_BY_LOCATION' \
    'TIME_ZONE' \
    'CLOCK_24_HOUR' \
    'SSH_REMOTE_LOGIN_ENABLED' \
    'SSHD_ALLOW_USERS' \
    'SSHD_LOGIN_KEY_FILES'
}

load_system_support_config() {
  local root_path="$1"

  clear_config_values \
    'SYSTEM_DOCK_DOMAIN' \
    'SYSTEM_DOCK_AUTO_HIDE_KEY' \
    'SYSTEM_DOCK_REORDER_SPACES_KEY' \
    'SYSTEM_DOCK_AUTO_HIDE_LOG_TOKEN' \
    'SYSTEM_DOCK_REORDER_SPACES_LOG_TOKEN' \
    'SYSTEM_PMSET_AC_POWER_SECTION' \
    'SYSTEM_PMSET_SLEEP_LOG_TOKEN' \
    'SYSTEM_PMSET_PORTABLE_SLEEP_SCOPE' \
    'SYSTEM_PMSET_NON_PORTABLE_SLEEP_SCOPE' \
    'SYSTEM_TIME_ZONE_AUTO_LOG_TOKEN' \
    'SYSTEM_TIME_ZONE_LOG_TOKEN' \
    'SYSTEM_CLOCK_24_HOUR_LOG_TOKEN' \
    'SSHD_PASSWORD_AUTHENTICATION' \
    'SSHD_KBD_INTERACTIVE_AUTHENTICATION' \
    'SSHD_CHALLENGE_RESPONSE_AUTHENTICATION' \
    'SSHD_PERMIT_ROOT_LOGIN' \
    'SSHD_PUBKEY_AUTHENTICATION' \
    'SSHD_X11_FORWARDING' \
    'SSHD_ALLOW_TCP_FORWARDING' \
    'SSHD_ALLOW_AGENT_FORWARDING' \
    'SYSTEM_REMOTE_LOGIN_LOG_TOKEN' \
    'SYSTEM_SSHD_CONFIG_LOG_TOKEN' \
    'SYSTEM_SSHD_AUTHORIZED_KEY_LOG_TOKEN' \
    'SYSTEM_SSHD_HOST_KEYS_LOG_TOKEN' \
    'SYSTEM_SSHD_CONFIG_DIR' \
    'SYSTEM_SSHD_MANAGED_FILE_NAME' \
    'SYSTEM_SSHD_AUTHORIZED_KEYS_DIR_NAME' \
    'SYSTEM_SSHD_HOST_ED25519_KEY_PATH' \
    'SYSTEM_SSHD_HOST_RSA_KEY_PATH' \
    'SYSTEM_SSHD_HOST_ECDSA_KEY_PATH'
  load_required_config "$root_path" 'configs/shared/system/system-configure.conf'
}

support_config_value_names() {
  printf '%s\n' \
    'SYSTEM_DOCK_DOMAIN' \
    'SYSTEM_DOCK_AUTO_HIDE_KEY' \
    'SYSTEM_DOCK_REORDER_SPACES_KEY' \
    'SYSTEM_DOCK_AUTO_HIDE_LOG_TOKEN' \
    'SYSTEM_DOCK_REORDER_SPACES_LOG_TOKEN' \
    'SYSTEM_PMSET_AC_POWER_SECTION' \
    'SYSTEM_PMSET_SLEEP_LOG_TOKEN' \
    'SYSTEM_PMSET_PORTABLE_SLEEP_SCOPE' \
    'SYSTEM_PMSET_NON_PORTABLE_SLEEP_SCOPE' \
    'SYSTEM_TIME_ZONE_AUTO_LOG_TOKEN' \
    'SYSTEM_TIME_ZONE_LOG_TOKEN' \
    'SYSTEM_CLOCK_24_HOUR_LOG_TOKEN' \
    'SSHD_PASSWORD_AUTHENTICATION' \
    'SSHD_KBD_INTERACTIVE_AUTHENTICATION' \
    'SSHD_CHALLENGE_RESPONSE_AUTHENTICATION' \
    'SSHD_PERMIT_ROOT_LOGIN' \
    'SSHD_PUBKEY_AUTHENTICATION' \
    'SSHD_X11_FORWARDING' \
    'SSHD_ALLOW_TCP_FORWARDING' \
    'SSHD_ALLOW_AGENT_FORWARDING' \
    'SYSTEM_REMOTE_LOGIN_LOG_TOKEN' \
    'SYSTEM_SSHD_CONFIG_LOG_TOKEN' \
    'SYSTEM_SSHD_AUTHORIZED_KEY_LOG_TOKEN' \
    'SYSTEM_SSHD_HOST_KEYS_LOG_TOKEN' \
    'SYSTEM_SSHD_CONFIG_DIR' \
    'SYSTEM_SSHD_MANAGED_FILE_NAME' \
    'SYSTEM_SSHD_AUTHORIZED_KEYS_DIR_NAME' \
    'SYSTEM_SSHD_HOST_ED25519_KEY_PATH' \
    'SYSTEM_SSHD_HOST_RSA_KEY_PATH' \
    'SYSTEM_SSHD_HOST_ECDSA_KEY_PATH'
}

require_support_config_values() {
  local config_name

  while IFS= read -r config_name; do
    require_config_value "$config_name"
  done < <(support_config_value_names)
}

add_system_config_candidate_if_present() {
  local config_path="$1"

  if [[ -f "$config_path" ]]; then
    SYSTEM_CONFIGS+=("$config_path")
  fi
}

resolve_system_configs() {
  local root_path="$1"
  local os_name="$2"
  local host_name="$3"
  local user_name="$4"

  SYSTEM_CONFIGS=()
  add_system_config_candidate_if_present "$root_path/configs/shared/system/system-shared-shared.conf"
  add_system_config_candidate_if_present "$root_path/configs/shared/system/system-shared-$user_name.conf"
  add_system_config_candidate_if_present "$root_path/configs/shared/system/system-$host_name-shared.conf"
  add_system_config_candidate_if_present "$root_path/configs/shared/system/system-$host_name-$user_name.conf"
  add_system_config_candidate_if_present "$root_path/configs/$os_name/system/system-shared-shared.conf"
  add_system_config_candidate_if_present "$root_path/configs/$os_name/system/system-shared-$user_name.conf"
  add_system_config_candidate_if_present "$root_path/configs/$os_name/system/system-$host_name-shared.conf"
  add_system_config_candidate_if_present "$root_path/configs/$os_name/system/system-$host_name-$user_name.conf"

}

load_system_configs() {
  local config_path

  clear_optional_system_setting_values

  for config_path in "${SYSTEM_CONFIGS[@]-}"; do
    [[ -n "$config_path" ]] || continue
    # shellcheck disable=SC1090
    source "$config_path"
  done
}

has_setting_value() {
  local setting_name="$1"
  [[ -n "${!setting_name+x}" ]]
}

should_manage_dock_auto_hide() {
  has_setting_value 'DOCK_AUTO_HIDE'
}

should_manage_dock_spaces() {
  has_setting_value 'DOCK_REORDER_SPACES_BY_RECENT_USE'
}

should_manage_sleep() {
  has_setting_value 'AC_POWER_SYSTEM_SLEEP_MINUTES'
}

should_manage_time_zone_auto_by_location() {
  has_setting_value 'TIME_ZONE_AUTO_BY_LOCATION'
}

should_manage_time_zone() {
  has_setting_value 'TIME_ZONE'
}

should_manage_clock_24_hour() {
  has_setting_value 'CLOCK_24_HOUR'
}

should_manage_time_settings() {
  should_manage_time_zone_auto_by_location || should_manage_time_zone || should_manage_clock_24_hour
}

should_manage_ssh() {
  has_setting_value 'SSH_REMOTE_LOGIN_ENABLED' || has_setting_value 'SSHD_ALLOW_USERS' || has_setting_value 'SSHD_LOGIN_KEY_FILES'
}

# Convert repo config booleans to the values expected by defaults.
bool_to_defaults_value() {
  case "$1" in
    true) printf 'true\n' ;;
    false) printf 'false\n' ;;
    *) fail "Invalid boolean value: $1" ;;
  esac
}

bool_to_sshd_yes_no() {
  case "$1" in
    true) printf 'yes\n' ;;
    false) printf 'no\n' ;;
    *) fail "Invalid boolean value: $1" ;;
  esac
}

# Normalize defaults boolean reads so comparisons stay stable.
normalize_defaults_bool_value() {
  case "$1" in
    1|true) printf 'true\n' ;;
    0|false) printf 'false\n' ;;
    *) fail "Invalid defaults boolean value: $1" ;;
  esac
}

# Validate one repo config boolean before any system writes happen.
validate_repo_bool_value() {
  case "$2" in
    true|false) ;;
    *) fail "Invalid $1 value: $2" ;;
  esac
}

# Validate one managed sleep value before any system writes happen.
validate_non_negative_integer() {
  case "$2" in
    ''|*[!0-9]*) fail "Invalid $1 value: $2" ;;
    *) ;;
  esac
}

# Validate one managed pmset scope against the current workflow contract.
validate_pmset_scope_value() {
  case "$2" in
    -a|-c) ;;
    *) fail "Invalid $1 value: $2" ;;
  esac
}

validate_safe_file_name() {
  local variable_name="$1"
  local file_name="$2"

  [[ -n "$file_name" ]] || fail "$variable_name must not be empty"
  [[ "$file_name" != */* ]] || fail "$variable_name must not contain /: $file_name"
  [[ "$file_name" != *$'\n'* ]] || fail "$variable_name must not contain newlines: $file_name"
}

validate_time_zone_value() {
  local zone_name="$1"
  local listed_zones

  [[ -n "$zone_name" ]] || fail 'TIME_ZONE must not be empty'
  listed_zones="$(systemsetup -listtimezones 2>/dev/null || true)"
  printf '%s\n' "$listed_zones" | grep -Fx -- "$zone_name" >/dev/null 2>&1 || fail "Invalid TIME_ZONE value: $zone_name"
}

repo_ssh_keys_dir_path() {
  local root_path="$1"
  printf '%s/keys/macos/ssh\n' "$root_path"
}

managed_sshd_config_path() {
  printf '%s/%s\n' "$SYSTEM_SSHD_CONFIG_DIR" "$SYSTEM_SSHD_MANAGED_FILE_NAME"
}

authorized_keys_dir_path_for_home() {
  local user_home="$1"
  printf '%s/.ssh/%s\n' "$user_home" "$SYSTEM_SSHD_AUTHORIZED_KEYS_DIR_NAME"
}

user_home_directory() {
  local user_name="$1"
  local dscl_output
  local home_path

  dscl_output="$(dscl . -read "/Users/$user_name" NFSHomeDirectory 2>/dev/null || true)"
  home_path="${dscl_output#NFSHomeDirectory: }"
  [[ -n "$home_path" && "$home_path" != "$dscl_output" ]] || fail "Unable to resolve home directory for user: $user_name"
  printf '%s\n' "$home_path"
}

current_remote_login_enabled() {
  local status_output

  status_output="$(sudo systemsetup -getremotelogin 2>/dev/null || true)"
  [[ "$status_output" == *'On'* ]]
}

current_time_zone_auto_by_location_enabled() {
  local read_value

  if read_value="$(sudo defaults read /Library/Preferences/com.apple.timezone.auto Active 2>/dev/null)"; then
    [[ "$(normalize_defaults_bool_value "$read_value")" == 'true' ]]
  else
    return 1
  fi
}

current_time_zone() {
  local status_output

  status_output="$(systemsetup -gettimezone 2>/dev/null || true)"
  printf '%s\n' "${status_output#Time Zone: }"
}

current_24_hour_clock_enabled() {
  local force_24
  local force_12

  if force_24="$(defaults read -g AppleICUForce24HourTime 2>/dev/null)"; then
    force_24="$(normalize_defaults_bool_value "$force_24")"
  else
    force_24='false'
  fi

  if force_12="$(defaults read -g AppleICUForce12HourTime 2>/dev/null)"; then
    force_12="$(normalize_defaults_bool_value "$force_12")"
  else
    force_12='true'
  fi

  [[ "$force_24" == 'true' && "$force_12" == 'false' ]]
}

render_sshd_managed_config() {
  local password_authentication
  local kbd_interactive_authentication
  local challenge_response_authentication
  local permit_root_login
  local pubkey_authentication
  local x11_forwarding
  local allow_tcp_forwarding
  local allow_agent_forwarding

  password_authentication="$(bool_to_sshd_yes_no "$SSHD_PASSWORD_AUTHENTICATION")"
  kbd_interactive_authentication="$(bool_to_sshd_yes_no "$SSHD_KBD_INTERACTIVE_AUTHENTICATION")"
  challenge_response_authentication="$(bool_to_sshd_yes_no "$SSHD_CHALLENGE_RESPONSE_AUTHENTICATION")"
  permit_root_login="$(bool_to_sshd_yes_no "$SSHD_PERMIT_ROOT_LOGIN")"
  pubkey_authentication="$(bool_to_sshd_yes_no "$SSHD_PUBKEY_AUTHENTICATION")"
  x11_forwarding="$(bool_to_sshd_yes_no "$SSHD_X11_FORWARDING")"
  allow_tcp_forwarding="$(bool_to_sshd_yes_no "$SSHD_ALLOW_TCP_FORWARDING")"
  allow_agent_forwarding="$(bool_to_sshd_yes_no "$SSHD_ALLOW_AGENT_FORWARDING")"

  cat <<EOF
HostKey $SYSTEM_SSHD_HOST_ED25519_KEY_PATH
PasswordAuthentication $password_authentication
KbdInteractiveAuthentication $kbd_interactive_authentication
ChallengeResponseAuthentication $challenge_response_authentication
PermitRootLogin $permit_root_login
PubkeyAuthentication $pubkey_authentication
X11Forwarding $x11_forwarding
AllowTcpForwarding $allow_tcp_forwarding
AllowAgentForwarding $allow_agent_forwarding
AllowUsers $SSHD_ALLOW_USERS
AuthorizedKeysFile .ssh/authorized_keys .ssh/$SYSTEM_SSHD_AUTHORIZED_KEYS_DIR_NAME/*
EOF
}

write_root_owned_file_if_changed() {
  local target_file_path="$1"
  local file_content="$2"
  local target_dir
  local temp_file

  target_dir="$(command dirname "$target_file_path")"
  temp_file="$(mktemp)"
  printf '%s\n' "$file_content" > "$temp_file"

  if [[ -f "$target_file_path" ]] && cmp -s "$temp_file" "$target_file_path"; then
    rm -f "$temp_file"
    return 1
  fi

  sudo mkdir -p "$target_dir"
  sudo cp "$temp_file" "$target_file_path"
  sudo chmod 644 "$target_file_path"
  rm -f "$temp_file"
  return 0
}

remove_root_owned_file_if_present() {
  local target_file_path="$1"

  [[ -e "$target_file_path" ]] || return 1
  sudo rm -f "$target_file_path"
  return 0
}

write_user_owned_file_if_changed() {
  local target_file_path="$1"
  local file_content="$2"
  local target_dir
  local temp_file

  target_dir="$(command dirname "$target_file_path")"
  temp_file="$(mktemp)"
  printf '%s\n' "$file_content" > "$temp_file"

  if [[ -f "$target_file_path" ]] && cmp -s "$temp_file" "$target_file_path"; then
    rm -f "$temp_file"
    return 1
  fi

  command mkdir -p "$target_dir"
  command cp "$temp_file" "$target_file_path"
  command chmod 600 "$target_file_path"
  rm -f "$temp_file"
  return 0
}

remove_user_owned_file_if_present() {
  local target_file_path="$1"

  [[ -e "$target_file_path" ]] || return 1
  command rm -f "$target_file_path"
  return 0
}

host_key_public_path() {
  printf '%s.pub\n' "$1"
}

ed25519_host_key_exists() {
  [[ -f "$SYSTEM_SSHD_HOST_ED25519_KEY_PATH" ]]
}

remove_non_ed25519_host_keys() {
  local host_keys_changed='1'
  local key_path

  for key_path in "$SYSTEM_SSHD_HOST_RSA_KEY_PATH" "$SYSTEM_SSHD_HOST_ECDSA_KEY_PATH"; do
    if remove_root_owned_file_if_present "$key_path"; then
      host_keys_changed='0'
    fi
    if remove_root_owned_file_if_present "$(host_key_public_path "$key_path")"; then
      host_keys_changed='0'
    fi
  done

  [[ "$host_keys_changed" == '0' ]]
}

ensure_sshd_host_keys() {
  local host_keys_changed='1'

  if ! ed25519_host_key_exists; then
    if ! sudo ssh-keygen -A; then
      fail 'Unable to generate missing SSH host keys with ssh-keygen -A'
    fi
    host_keys_changed='0'
  fi

  ed25519_host_key_exists || fail "Required SSH host key is missing after generation: $SYSTEM_SSHD_HOST_ED25519_KEY_PATH"

  if remove_non_ed25519_host_keys; then
    host_keys_changed='0'
  fi

  if [[ "$host_keys_changed" == '0' ]]; then
    append_activity_log_row "$LOG_FILE_PATH" "$LOG_HOST_NAME" "$ACTION_CONFIGURED" "$SYSTEM_SSHD_HOST_KEYS_LOG_TOKEN" ''
  fi
}

sync_managed_authorized_key_files() {
  local root_path="$1"
  local user_home="$2"
  local repo_key_dir
  local authorized_keys_dir
  local key_file_name
  local repo_key_path
  local managed_key_path
  local key_content
  local deployed_key_candidate
  local deployed_key_name
  local keys_changed='1'

  repo_key_dir="$(repo_ssh_keys_dir_path "$root_path")"
  authorized_keys_dir="$(authorized_keys_dir_path_for_home "$user_home")"

  command mkdir -p "$user_home/.ssh" "$authorized_keys_dir"
  command chmod 700 "$user_home/.ssh" "$authorized_keys_dir"

  for key_file_name in $SSHD_LOGIN_KEY_FILES; do
    validate_safe_file_name 'SSHD_LOGIN_KEY_FILES entry' "$key_file_name"
    repo_key_path="$repo_key_dir/$key_file_name"
    [[ -f "$repo_key_path" ]] || fail "SSH login key file not found: $repo_key_path"
    key_content="$(<"$repo_key_path")"
    [[ -n "$key_content" && "$key_content" != *$'\n'* ]] || fail "SSH login key file must contain one key line: $repo_key_path"
    managed_key_path="$authorized_keys_dir/$key_file_name"
    if write_user_owned_file_if_changed "$managed_key_path" "$key_content"; then
      keys_changed='0'
    fi
  done

  for deployed_key_candidate in "$authorized_keys_dir"/*.pub; do
    [[ -e "$deployed_key_candidate" ]] || continue
    deployed_key_name="$(basename "$deployed_key_candidate")"
    if ! contains_pub_file_name "$deployed_key_name"; then
      continue
    fi

    if contains_distinct_word "$SSHD_LOGIN_KEY_FILES" "$deployed_key_name"; then
      continue
    fi

    if remove_user_owned_file_if_present "$authorized_keys_dir/$deployed_key_name"; then
      keys_changed='0'
    fi
  done

  [[ "$keys_changed" == '0' ]]
}

remove_managed_authorized_key_files() {
  local root_path="$1"
  local user_home="$2"
  local authorized_keys_dir
  local deployed_key_candidate
  local deployed_key_name
  local keys_changed='1'

  authorized_keys_dir="$(authorized_keys_dir_path_for_home "$user_home")"

  [[ -d "$authorized_keys_dir" ]] || return 1

  for deployed_key_candidate in "$authorized_keys_dir"/*.pub; do
    [[ -e "$deployed_key_candidate" ]] || continue
    deployed_key_name="$(basename "$deployed_key_candidate")"
    if ! contains_pub_file_name "$deployed_key_name"; then
      continue
    fi

    if remove_user_owned_file_if_present "$authorized_keys_dir/$deployed_key_name"; then
      keys_changed='0'
    fi
  done

  [[ "$keys_changed" == '0' ]]
}

validate_sshd_configuration() {
  sudo sshd -t
}

reload_sshd() {
  sudo launchctl kickstart -k system/com.openssh.sshd
}

apply_ssh_settings() {
  local root_path="$1"
  local user_home
  local sshd_config_path
  local sshd_config_changed='1'
  local authorized_keys_changed='1'

  user_home="$(user_home_directory 'ezirius')"
  sshd_config_path="$(managed_sshd_config_path)"

  if [[ "$SSH_REMOTE_LOGIN_ENABLED" == 'false' ]]; then
    if current_remote_login_enabled; then
      sudo systemsetup -setremotelogin off
      append_activity_log_row "$LOG_FILE_PATH" "$LOG_HOST_NAME" "$ACTION_CONFIGURED" "$SYSTEM_REMOTE_LOGIN_LOG_TOKEN" ''
    fi

    if remove_root_owned_file_if_present "$sshd_config_path"; then
      append_activity_log_row "$LOG_FILE_PATH" "$LOG_HOST_NAME" "$ACTION_CONFIGURED" "$SYSTEM_SSHD_CONFIG_LOG_TOKEN" ''
    fi

    if remove_managed_authorized_key_files "$root_path" "$user_home"; then
      append_activity_log_row "$LOG_FILE_PATH" "$LOG_HOST_NAME" "$ACTION_CONFIGURED" "$SYSTEM_SSHD_AUTHORIZED_KEY_LOG_TOKEN" ''
    fi

    return 0
  fi

  if sync_managed_authorized_key_files "$root_path" "$user_home"; then
    authorized_keys_changed='0'
    append_activity_log_row "$LOG_FILE_PATH" "$LOG_HOST_NAME" "$ACTION_CONFIGURED" "$SYSTEM_SSHD_AUTHORIZED_KEY_LOG_TOKEN" ''
  fi

  if write_root_owned_file_if_changed "$sshd_config_path" "$(render_sshd_managed_config)"; then
    sshd_config_changed='0'
    append_activity_log_row "$LOG_FILE_PATH" "$LOG_HOST_NAME" "$ACTION_CONFIGURED" "$SYSTEM_SSHD_CONFIG_LOG_TOKEN" ''
  fi

  if [[ "$sshd_config_changed" == '0' ]] || ! current_remote_login_enabled; then
    validate_sshd_configuration
  fi

  if current_remote_login_enabled; then
    if [[ "$sshd_config_changed" == '0' ]]; then
      reload_sshd
    fi
  else
    sudo systemsetup -setremotelogin on
    append_activity_log_row "$LOG_FILE_PATH" "$LOG_HOST_NAME" "$ACTION_CONFIGURED" "$SYSTEM_REMOTE_LOGIN_LOG_TOKEN" ''
  fi

  [[ "$authorized_keys_changed" == '0' ]] && :
}

# Update one Dock boolean key only when the current value differs.
set_dock_bool() {
  local key_name="$1"
  local desired_value="$2"
  local application_name="$3"
  local read_value
  local current_value

  if read_value="$(defaults read "$SYSTEM_DOCK_DOMAIN" "$key_name" 2>/dev/null)"; then
    current_value="$(normalize_defaults_bool_value "$read_value")"
  else
    current_value='__unset__'
  fi
  desired_value="$(bool_to_defaults_value "$desired_value")"

  if [[ "$current_value" == "$desired_value" ]]; then
    return 0
  fi

  defaults write "$SYSTEM_DOCK_DOMAIN" "$key_name" -bool "$desired_value"
  DOCK_CHANGED='1'
  append_activity_log_row "$LOG_FILE_PATH" "$LOG_HOST_NAME" "$ACTION_CONFIGURED" "$application_name" ''
}

# Apply the managed Dock settings as one grouped operation.
apply_dock_settings() {
  if should_manage_dock_auto_hide; then
    set_dock_bool "$SYSTEM_DOCK_AUTO_HIDE_KEY" "$DOCK_AUTO_HIDE" "$SYSTEM_DOCK_AUTO_HIDE_LOG_TOKEN"
  fi

  if should_manage_dock_spaces; then
    set_dock_bool "$SYSTEM_DOCK_REORDER_SPACES_KEY" "$DOCK_REORDER_SPACES_BY_RECENT_USE" "$SYSTEM_DOCK_REORDER_SPACES_LOG_TOKEN"
  fi
}

# Detect whether the current Mac should use the portable pmset scope.
mac_is_portable() {
  local battery_output

  battery_output="$(pmset -g batt 2>/dev/null || true)"

  [[ "$battery_output" == *'Battery Power'* || "$battery_output" == *'InternalBattery'* ]]
}

# Read the current sleep value from the requested pmset section.
current_pmset_sleep_setting() {
  local power_section="$1"
  local pmset_output

  pmset_output="$(pmset -g custom 2>/dev/null || true)"
  awk -v section="$power_section" '
    $0 == section":" { in_section = 1; next }
    /^[A-Za-z].*:$/ { in_section = 0 }
    in_section && $1 == "sleep" { print $2; exit }
  ' <<< "$pmset_output"
}

# Apply the managed AC power sleep value only when it differs.
apply_pmset_sleep() {
  local desired_value="$1"
  local scope_flag="$SYSTEM_PMSET_NON_PORTABLE_SLEEP_SCOPE"
  local current_value

  if mac_is_portable; then
    scope_flag="$SYSTEM_PMSET_PORTABLE_SLEEP_SCOPE"
  fi

  current_value="$(current_pmset_sleep_setting "$SYSTEM_PMSET_AC_POWER_SECTION" || true)"
  if [[ "$current_value" == "$desired_value" ]]; then
    return 0
  fi

  sudo -v
  sudo pmset "$scope_flag" sleep "$desired_value"
  append_activity_log_row "$LOG_FILE_PATH" "$LOG_HOST_NAME" "$ACTION_CONFIGURED" "$SYSTEM_PMSET_SLEEP_LOG_TOKEN" ''
}

apply_time_zone_auto_by_location() {
  local desired_value="$1"
  local current_value='false'

  if current_time_zone_auto_by_location_enabled; then
    current_value='true'
  fi

  if [[ "$current_value" == "$desired_value" ]]; then
    return 0
  fi

  sudo defaults write /Library/Preferences/com.apple.timezone.auto Active -bool "$desired_value"
  append_activity_log_row "$LOG_FILE_PATH" "$LOG_HOST_NAME" "$ACTION_CONFIGURED" "$SYSTEM_TIME_ZONE_AUTO_LOG_TOKEN" ''
}

apply_time_zone() {
  local desired_value="$1"
  local current_value

  current_value="$(current_time_zone)"
  if [[ "$current_value" == "$desired_value" ]]; then
    return 0
  fi

  sudo systemsetup -settimezone "$desired_value"
  append_activity_log_row "$LOG_FILE_PATH" "$LOG_HOST_NAME" "$ACTION_CONFIGURED" "$SYSTEM_TIME_ZONE_LOG_TOKEN" ''
}

apply_24_hour_clock() {
  local desired_value="$1"
  local current_value='false'

  if current_24_hour_clock_enabled; then
    current_value='true'
  fi

  if [[ "$current_value" == "$desired_value" ]]; then
    return 0
  fi

  defaults write -g AppleICUForce24HourTime -bool "$desired_value"
  if [[ "$desired_value" == 'true' ]]; then
    defaults write -g AppleICUForce12HourTime -bool false
  else
    defaults write -g AppleICUForce12HourTime -bool true
  fi
  killall cfprefsd SystemUIServer >/dev/null 2>&1 || true
  append_activity_log_row "$LOG_FILE_PATH" "$LOG_HOST_NAME" "$ACTION_CONFIGURED" "$SYSTEM_CLOCK_24_HOUR_LOG_TOKEN" ''
}

# Validate that every required config value was provided by the chosen file.
validate_config() {
  require_support_config_values

  validate_pmset_scope_value 'SYSTEM_PMSET_PORTABLE_SLEEP_SCOPE' "$SYSTEM_PMSET_PORTABLE_SLEEP_SCOPE"
  validate_pmset_scope_value 'SYSTEM_PMSET_NON_PORTABLE_SLEEP_SCOPE' "$SYSTEM_PMSET_NON_PORTABLE_SLEEP_SCOPE"
  validate_repo_bool_value 'SSHD_PASSWORD_AUTHENTICATION' "$SSHD_PASSWORD_AUTHENTICATION"
  validate_repo_bool_value 'SSHD_KBD_INTERACTIVE_AUTHENTICATION' "$SSHD_KBD_INTERACTIVE_AUTHENTICATION"
  validate_repo_bool_value 'SSHD_CHALLENGE_RESPONSE_AUTHENTICATION' "$SSHD_CHALLENGE_RESPONSE_AUTHENTICATION"
  validate_repo_bool_value 'SSHD_PERMIT_ROOT_LOGIN' "$SSHD_PERMIT_ROOT_LOGIN"
  validate_repo_bool_value 'SSHD_PUBKEY_AUTHENTICATION' "$SSHD_PUBKEY_AUTHENTICATION"
  validate_repo_bool_value 'SSHD_X11_FORWARDING' "$SSHD_X11_FORWARDING"
  validate_repo_bool_value 'SSHD_ALLOW_TCP_FORWARDING' "$SSHD_ALLOW_TCP_FORWARDING"
  validate_repo_bool_value 'SSHD_ALLOW_AGENT_FORWARDING' "$SSHD_ALLOW_AGENT_FORWARDING"

  if should_manage_dock_auto_hide; then
    validate_repo_bool_value 'DOCK_AUTO_HIDE' "$DOCK_AUTO_HIDE"
  fi

  if should_manage_dock_spaces; then
    validate_repo_bool_value 'DOCK_REORDER_SPACES_BY_RECENT_USE' "$DOCK_REORDER_SPACES_BY_RECENT_USE"
  fi

  if should_manage_sleep; then
    validate_non_negative_integer 'AC_POWER_SYSTEM_SLEEP_MINUTES' "$AC_POWER_SYSTEM_SLEEP_MINUTES"
  fi

  if should_manage_time_zone_auto_by_location; then
    validate_repo_bool_value 'TIME_ZONE_AUTO_BY_LOCATION' "$TIME_ZONE_AUTO_BY_LOCATION"
  fi

  if should_manage_time_zone; then
    validate_time_zone_value "$TIME_ZONE"
  fi

  if should_manage_clock_24_hour; then
    validate_repo_bool_value 'CLOCK_24_HOUR' "$CLOCK_24_HOUR"
  fi

  if should_manage_ssh; then
    [[ -n "${SSH_REMOTE_LOGIN_ENABLED:-}" ]] || fail 'SSH_REMOTE_LOGIN_ENABLED must be set when SSH settings are managed'
    validate_repo_bool_value 'SSH_REMOTE_LOGIN_ENABLED' "$SSH_REMOTE_LOGIN_ENABLED"
  fi

  if [[ "${SSH_REMOTE_LOGIN_ENABLED:-false}" == 'true' ]]; then
    [[ -n "${SSHD_ALLOW_USERS:-}" ]] || fail 'SSHD_ALLOW_USERS must be set when SSH_REMOTE_LOGIN_ENABLED is true'
    [[ "$SSHD_ALLOW_USERS" == 'ezirius' ]] || fail 'SSHD_ALLOW_USERS must be exactly ezirius when SSH_REMOTE_LOGIN_ENABLED is true'
    [[ -n "${SSHD_LOGIN_KEY_FILES:-}" ]] || fail 'SSHD_LOGIN_KEY_FILES must be set when SSH_REMOTE_LOGIN_ENABLED is true'
    for key_file_name in $SSHD_LOGIN_KEY_FILES; do
      validate_safe_file_name 'SSHD_LOGIN_KEY_FILES entry' "$key_file_name"
      [[ -f "$(repo_ssh_keys_dir_path "$ROOT_PATH")/$key_file_name" ]] || fail "SSH login key file not found: $(repo_ssh_keys_dir_path "$ROOT_PATH")/$key_file_name"
    done
  fi
}

main() {
  local root_path
  local os_name
  local host_name
  local user_name

  if is_help_flag "${1-}"; then
    show_usage
  fi

  if [[ $# -ne 0 ]]; then
    fail 'system-configure takes no arguments. Use --help for usage.'
  fi

  require_macos
  require_command defaults
  require_command pmset
  require_command sudo
  require_command awk
  require_command killall
  require_command systemsetup
  require_command sshd
  require_command launchctl
  require_command dscl
  require_command cmp
  require_command ssh-keygen

  root_path="$(repo_root_from_script_path "$SCRIPT_PATH")"
  ROOT_PATH="$root_path"
  load_shared_logging_config "$root_path"
  load_system_support_config "$root_path"
  os_name="$(detect_os)"
  host_name="$(detect_host)"
  user_name="$(detect_username)"
  resolve_system_configs "$root_path" "$os_name" "$host_name" "$user_name"
  DOCK_CHANGED='0'
  LOG_HOST_NAME="$host_name"
  LOG_FILE_PATH="$(activity_log_file_path "$root_path" "$os_name" "$host_name")"

  print_green 'Loading managed macOS system config'
  load_system_configs
  validate_config

  if should_manage_dock_auto_hide || should_manage_dock_spaces; then
    print_green 'Applying Dock settings'
    apply_dock_settings

    if [[ "$DOCK_CHANGED" == '1' ]]; then
      killall Dock >/dev/null 2>&1 || true
    fi
  fi

  if should_manage_sleep; then
    print_green 'Applying power settings'
    apply_pmset_sleep "$AC_POWER_SYSTEM_SLEEP_MINUTES"
  fi

  if should_manage_time_settings; then
    print_green 'Applying time settings'
    if should_manage_time_zone_auto_by_location; then
      apply_time_zone_auto_by_location "$TIME_ZONE_AUTO_BY_LOCATION"
    fi
    if should_manage_time_zone; then
      apply_time_zone "$TIME_ZONE"
    fi
    if should_manage_clock_24_hour; then
      apply_24_hour_clock "$CLOCK_24_HOUR"
    fi
  fi

  ensure_sshd_host_keys

  if should_manage_ssh; then
    print_green 'Applying SSH settings'
    apply_ssh_settings "$root_path"
  fi

  print_green 'macOS system settings are ready'
}

main "$@"
