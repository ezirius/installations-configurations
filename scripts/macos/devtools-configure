#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/../../lib/shell/common.sh"

if [[ $# -ne 0 ]]; then
  usage_error "$(basename "$0") takes no arguments"
fi

ROOT="$(repo_root)"
CONFIG_ROOT="${XDG_CONFIG_HOME:-$HOME/.config}"
VIM_BRIDGE_PATH="$HOME/.vimrc"
LAZYGIT_COMPAT_PATH="$HOME/Library/Application Support/lazygit"
ZELLIJ_COMPAT_PATH="$HOME/Library/Application Support/org.Zellij-Contributors.Zellij"

copy_managed_file() {
  local source_path="$1"
  local target_path="$2"
  local item_name="$3"
  local details="$4"
  local change_name="Created"

  mkdir -p "$(dirname "$target_path")"

  if [[ -f "$target_path" ]] && cmp -s "$source_path" "$target_path"; then
    return 0
  fi

  if [[ -f "$target_path" ]]; then
    change_name="Updated"
  fi

  cp "$source_path" "$target_path"
  log_change "Configuration" "$item_name" "$change_name" "$target_path" "$details"
}

ensure_bridge_file() {
  local target_path="$1"
  local desired_content="$2"
  local item_name="$3"
  local details="$4"
  local change_name="Created"
  local temp_file

  temp_file="$(mktemp)"
  printf '%s\n' "$desired_content" > "$temp_file"

  if [[ -f "$target_path" ]] && cmp -s "$temp_file" "$target_path"; then
    rm -f "$temp_file"
    return 0
  fi

  mkdir -p "$(dirname "$target_path")"
  if [[ -f "$target_path" ]]; then
    change_name="Updated"
  fi

  mv "$temp_file" "$target_path"
  log_change "Configuration" "$item_name" "$change_name" "$target_path" "$details"
}

ensure_compat_symlink() {
  local target_dir="$1"
  local compat_path="$2"
  local item_name="$3"
  local details="$4"
  local current_target=""
  local change_name="Created"

  mkdir -p "$(dirname "$compat_path")"

  if [[ -L "$compat_path" ]]; then
    current_target="$(readlink "$compat_path")"
    if [[ "$current_target" == "$target_dir" ]]; then
      return 0
    fi
    rm "$compat_path"
    change_name="Updated"
  elif [[ -e "$compat_path" ]]; then
    fail "$item_name compatibility path already exists and is not a symlink: $compat_path"
  fi

  ln -s "$target_dir" "$compat_path"
  log_change "Configuration" "$item_name" "$change_name" "$compat_path" "$details"
}

deploy_tree() {
  local source_dir="$1"
  local target_dir="$2"
  local item_prefix="$3"
  local details_prefix="$4"
  local path
  local relative_path

  [[ -d "$source_dir" ]] || fail "Managed config directory not found: $source_dir"

  while IFS= read -r path; do
    relative_path="${path#$source_dir/}"
    copy_managed_file "$path" "$target_dir/$relative_path" "$item_prefix" "$details_prefix: $relative_path"
  done < <(find "$source_dir" -type f | sort)
}

require_macos
require_homebrew
require_clt
require_command cmp
require_command cp
require_command find
require_command sort
initialize_change_log "scripts/macos/devtools-configure"

echo "==> Deploying shared developer tool config"
deploy_tree "$ROOT/config/fd" "$CONFIG_ROOT/fd" "fd config" "Configured fd"
deploy_tree "$ROOT/config/bat" "$CONFIG_ROOT/bat" "bat config" "Configured bat"
deploy_tree "$ROOT/config/eza" "$CONFIG_ROOT/eza" "eza config" "Configured eza"
deploy_tree "$ROOT/config/tlrc" "$CONFIG_ROOT/tlrc" "tlrc config" "Configured tlrc"
deploy_tree "$ROOT/config/starship" "$CONFIG_ROOT/starship" "starship config" "Configured starship"
deploy_tree "$ROOT/config/atuin" "$CONFIG_ROOT/atuin" "atuin config" "Configured atuin"
deploy_tree "$ROOT/config/zellij" "$CONFIG_ROOT/zellij" "zellij config" "Configured zellij"
deploy_tree "$ROOT/config/btop" "$CONFIG_ROOT/btop" "btop config" "Configured btop"
deploy_tree "$ROOT/config/micro" "$CONFIG_ROOT/micro" "micro config" "Configured micro"
deploy_tree "$ROOT/config/vim" "$CONFIG_ROOT/vim" "vim config" "Configured vim"
deploy_tree "$ROOT/config/lazygit" "$CONFIG_ROOT/lazygit" "lazygit config" "Configured lazygit"

ensure_bridge_file "$VIM_BRIDGE_PATH" 'source ~/.config/vim/vimrc' "vim bridge" "Bridged ~/.vimrc to the managed ~/.config/vim/vimrc"
ensure_compat_symlink "$CONFIG_ROOT/zellij" "$ZELLIJ_COMPAT_PATH" "zellij compatibility symlink" "Linked the macOS Zellij config path to ~/.config/zellij"
ensure_compat_symlink "$CONFIG_ROOT/lazygit" "$LAZYGIT_COMPAT_PATH" "lazygit compatibility symlink" "Linked the macOS Lazygit config path to ~/.config/lazygit"

echo "==> Shared developer tool config is ready"
