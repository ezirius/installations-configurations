#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/../../lib/shell/common.sh"

if is_help_flag "${1-}"; then
  show_help "Usage: $(basename "$0") [brewfile-path]

Install missing managed Homebrew formulae and casks.

Arguments:
  [brewfile-path]  Optional explicit Brewfile override.

Notes:
  - Requires a clean, pushed repository state.
  - Does not upgrade already installed entries.
  - Triggers the Xcode Command Line Tools installer if CLT are missing.
  - Refuses to auto-install Homebrew itself."
fi

if [[ $# -gt 1 ]]; then
  usage_error "$(basename "$0") takes at most 1 argument: [brewfile-path]"
fi

ROOT="$(repo_root)"
BREWFILE_OVERRIDE="${1:-}"
BREW_PREFIX=""
ENTRIES_FILE=""
BEFORE_FILE=""
AFTER_FILE=""
CHANGES_FILE=""
PYTHON3_COMMAND=""

cleanup() {
  rm -f "$ENTRIES_FILE" "$BEFORE_FILE" "$AFTER_FILE" "$CHANGES_FILE"
}

trap cleanup EXIT

snapshot_brewfile_state() {
  local output_file="$1"
  local entry_type
  local entry_name
  local version_line

  : > "$output_file"

  while IFS='|' read -r entry_type entry_name; do
    version_line=""

    if [[ "$entry_type" == "brew" ]]; then
      version_line="$(brew list --versions "$entry_name" 2>/dev/null || true)"
    else
      version_line="$(brew list --cask --versions "$entry_name" 2>/dev/null || true)"
    fi

    if [[ -n "$version_line" ]]; then
      printf '%s|%s|installed|%s\n' "$entry_type" "$entry_name" "$version_line" >> "$output_file"
    else
      printf '%s|%s|missing|\n' "$entry_type" "$entry_name" >> "$output_file"
    fi
  done < "$ENTRIES_FILE"
}

process_brewfile() {
  local brewfile_path="$1"
  local entry_type
  local entry_name

  echo "==> Checking Brewfile: $brewfile_path"
  [[ -f "$brewfile_path" ]] || fail "Brewfile not found: $brewfile_path"

  parse_brewfile_entries "$brewfile_path" > "$ENTRIES_FILE"
  snapshot_brewfile_state "$BEFORE_FILE"

  echo "==> Installing missing Brewfile entries"
  while IFS='|' read -r entry_type entry_name; do
    [[ -n "$entry_name" ]] || continue

    if [[ "$entry_type" == "brew" ]]; then
      if ! brew list --versions "$entry_name" >/dev/null 2>&1; then
        brew install "$entry_name"
      fi
    else
      if ! brew list --cask --versions "$entry_name" >/dev/null 2>&1; then
        brew install --cask "$entry_name"
      fi
    fi
  done < "$ENTRIES_FILE"

  snapshot_brewfile_state "$AFTER_FILE"
  "$PYTHON3_COMMAND" - "$BEFORE_FILE" "$AFTER_FILE" <<'PY' > "$CHANGES_FILE"
from pathlib import Path
import sys

def read_state(path):
    rows = {}
    for line in Path(path).read_text().splitlines():
        entry_type, name, state, version = line.split("|", 3)
        rows[(entry_type, name)] = {"state": state, "version": version}
    return rows

before = read_state(sys.argv[1])
after = read_state(sys.argv[2])

for (entry_type, name), after_data in after.items():
    before_data = before[(entry_type, name)]
    if before_data["state"] == "missing" and after_data["state"] == "installed":
        print(f"{entry_type}|{name}|Installed")
PY

  while IFS='|' read -r entry_type entry_name change_name; do
    [[ -n "$entry_name" ]] || continue
    log_change "Installation" "$entry_name" "$change_name" "$BREW_PREFIX" "Managed by Brewfile"
  done < "$CHANGES_FILE"
}

require_macos
initialize_change_log "scripts/macos/brew-install"
require_command git
require_clean_pushed_repo_state "$ROOT" "brew-install"

echo "==> Checking Xcode Command Line Tools"
if ! xcode-select -p >/dev/null 2>&1; then
  echo "==> Xcode Command Line Tools are not installed"
  echo "==> Triggering Apple installer"
  xcode-select --install || true
  echo "==> Finish the Command Line Tools installation, then re-run this script"
  exit 1
fi

echo "==> Loading Homebrew into PATH if already installed"
load_homebrew_shellenv

if ! command -v brew >/dev/null 2>&1; then
  fail "Homebrew is not installed. This repository does not execute the upstream Homebrew installer automatically because the published install path is a moving script without an official SHA-256 verification artefact for this workflow. Install Homebrew manually, then re-run this script."
fi

echo "==> Homebrew already installed"
brew --version

require_homebrew
require_clt
require_command cmp
PYTHON3_COMMAND="$(preferred_python3_command)"

BREW_PREFIX="$(brew --prefix)"
ENTRIES_FILE="$(mktemp)"
BEFORE_FILE="$(mktemp)"
AFTER_FILE="$(mktemp)"
CHANGES_FILE="$(mktemp)"

if [[ -n "$BREWFILE_OVERRIDE" ]]; then
  process_brewfile "$BREWFILE_OVERRIDE"
else
  process_brewfile "$(shared_platform_config_path "config/brew" "Brewfile")"

  BREWFILE_OVERRIDE="$(host_platform_config_path "config/brew" "Brewfile")"
  if [[ -f "$BREWFILE_OVERRIDE" ]]; then
    process_brewfile "$BREWFILE_OVERRIDE"
  fi
fi

echo "==> Homebrew and missing Brewfile entries are installed"
