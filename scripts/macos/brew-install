#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/../../lib/shell/common.sh"

if is_help_flag "${1-}"; then
  show_help "Usage: $(basename "$0") [brewfile-path]

Install missing managed Homebrew formulae and casks.

Arguments:
  [brewfile-path]  Optional explicit Brewfile override.

Notes:
  - Requires a clean, pushed repository state.
  - Does not upgrade already installed entries.
  - Triggers the Xcode Command Line Tools installer if CLT are missing.
  - Refuses to auto-install Homebrew itself."
fi

if [[ $# -gt 1 ]]; then
  usage_error "$(basename "$0") takes at most 1 argument: [brewfile-path]"
fi

ROOT="$(repo_root)"
BREWFILE_OVERRIDE="${1:-}"
BREW_PREFIX=""
ENTRIES_FILE=""
BEFORE_FILE=""
AFTER_FILE=""
CHANGES_FILE=""
PYTHON3_COMMAND=""

cleanup() {
  rm -f "$ENTRIES_FILE" "$BEFORE_FILE" "$AFTER_FILE" "$CHANGES_FILE"
}

trap cleanup EXIT

install_missing_brew_entry() {
  local entry_type="$1"
  local entry_name="$2"

  if [[ "$entry_type" == "brew" ]]; then
    if ! brew list --versions "$entry_name" >/dev/null 2>&1; then
      brew install "$entry_name"
    fi
  elif [[ "$entry_type" == "cask" ]]; then
    if ! brew list --cask --versions "$entry_name" >/dev/null 2>&1; then
      brew install --cask "$entry_name"
    fi
  else
    fail "Unsupported Brewfile entry type: $entry_type"
  fi
}

process_brewfile() {
  local brewfile_path="$1"

  echo "==> Checking Brewfile: $brewfile_path"

  write_brewfile_entries "$brewfile_path" "$ENTRIES_FILE"
  snapshot_brew_entries_state "$ENTRIES_FILE" "$BEFORE_FILE"

  echo "==> Installing missing Brewfile entries"
  for_each_brew_entry "$ENTRIES_FILE" install_missing_brew_entry

  snapshot_brew_entries_state "$ENTRIES_FILE" "$AFTER_FILE"
  report_brew_install_state_changes "$BEFORE_FILE" "$AFTER_FILE" "$PYTHON3_COMMAND" > "$CHANGES_FILE"

  while IFS='|' read -r entry_type entry_name change_name; do
    [[ -n "$entry_name" ]] || continue
    log_change "Installation" "$entry_name" "$change_name" "$BREW_PREFIX" "Managed by Brewfile"
  done < "$CHANGES_FILE"
}

require_macos
initialize_change_log "scripts/macos/brew-install"
require_command git
require_clean_pushed_repo_state "$ROOT" "brew-install"

echo "==> Checking Xcode Command Line Tools"
if ! xcode-select -p >/dev/null 2>&1; then
  echo "==> Xcode Command Line Tools are not installed"
  echo "==> Triggering Apple installer"
  xcode-select --install || true
  echo "==> Finish the Command Line Tools installation, then re-run this script"
  exit 1
fi

echo "==> Loading Homebrew into PATH if already installed"
load_homebrew_shellenv

if ! command -v brew >/dev/null 2>&1; then
  fail "Homebrew is not installed. This repository does not execute the upstream Homebrew installer automatically because the published install path is a moving script without an official SHA-256 verification artefact for this workflow. Install Homebrew manually, then re-run this script."
fi

echo "==> Homebrew already installed"
brew --version

require_homebrew
require_clt
require_command cmp
PYTHON3_COMMAND="$(preferred_python3_command)"

BREW_PREFIX="$(brew --prefix)"
ENTRIES_FILE="$(mktemp)"
BEFORE_FILE="$(mktemp)"
AFTER_FILE="$(mktemp)"
CHANGES_FILE="$(mktemp)"

if [[ -n "$BREWFILE_OVERRIDE" ]]; then
  for_each_managed_brewfile process_brewfile "$BREWFILE_OVERRIDE"
else
  for_each_managed_brewfile process_brewfile
fi

echo "==> Homebrew and missing Brewfile entries are installed"
