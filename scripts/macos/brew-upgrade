#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/../../lib/shell/common.sh"

if [[ $# -gt 1 ]]; then
  usage_error "$(basename "$0") takes at most 1 argument: [brewfile-path]"
fi

ROOT="$(repo_root)"
BREWFILE_OVERRIDE="${1:-}"
BREW_PREFIX=""
ENTRIES_FILE=""
BEFORE_FILE=""
AFTER_FILE=""
CHANGES_FILE=""
BREW_UPDATE_OUTPUT_FILE=""
PYTHON3_COMMAND=""

cleanup() {
  rm -f "$ENTRIES_FILE" "$BEFORE_FILE" "$AFTER_FILE" "$CHANGES_FILE" "$BREW_UPDATE_OUTPUT_FILE"
}

trap cleanup EXIT

snapshot_brewfile_state() {
  local output_file="$1"
  local entry_type
  local entry_name
  local version_line

  : > "$output_file"

  while IFS='|' read -r entry_type entry_name; do
    version_line=""

    if [[ "$entry_type" == "brew" ]]; then
      version_line="$(brew list --versions "$entry_name" 2>/dev/null || true)"
    else
      version_line="$(brew list --cask --versions "$entry_name" 2>/dev/null || true)"
    fi

    if [[ -n "$version_line" ]]; then
      printf '%s|%s|installed|%s\n' "$entry_type" "$entry_name" "$version_line" >> "$output_file"
    else
      printf '%s|%s|missing|\n' "$entry_type" "$entry_name" >> "$output_file"
    fi
  done < "$ENTRIES_FILE"
}

entry_is_outdated() {
  local entry_type="$1"
  local entry_name="$2"
  local outdated_output

  if [[ "$entry_type" == "brew" ]]; then
    outdated_output="$(brew outdated --formula "$entry_name" 2>/dev/null || true)"
  else
    outdated_output="$(brew outdated --cask "$entry_name" 2>/dev/null || true)"
  fi

  [[ -n "$outdated_output" ]]
}

write_brewfile_entries() {
  local brewfile_path="$1"

  "$PYTHON3_COMMAND" - "$brewfile_path" <<'PY' > "$ENTRIES_FILE"
import pathlib
import re
import sys

brewfile = pathlib.Path(sys.argv[1]).read_text().splitlines()
pattern = re.compile(r'^(brew|cask)\s+"([^"]+)"')

for line in brewfile:
    match = pattern.match(line.strip())
    if match:
        print(f"{match.group(1)}|{match.group(2)}")
PY
}

upgrade_brewfile_entries() {
  local brewfile_path="$1"
  local entry_type
  local entry_name

  echo "==> Checking Brewfile: $brewfile_path"
  [[ -f "$brewfile_path" ]] || fail "Brewfile not found: $brewfile_path"

  write_brewfile_entries "$brewfile_path"
  snapshot_brewfile_state "$BEFORE_FILE"

  echo "==> Upgrading installed outdated Brewfile entries: $brewfile_path"
  while IFS='|' read -r entry_type entry_name; do
    [[ -n "$entry_name" ]] || continue

    if [[ "$entry_type" == "brew" ]]; then
      if brew list --versions "$entry_name" >/dev/null 2>&1 && entry_is_outdated "brew" "$entry_name"; then
        brew upgrade "$entry_name"
      fi
    else
      if brew list --cask --versions "$entry_name" >/dev/null 2>&1 && entry_is_outdated "cask" "$entry_name"; then
        brew upgrade --cask "$entry_name"
      fi
    fi
  done < "$ENTRIES_FILE"

  snapshot_brewfile_state "$AFTER_FILE"

  "$PYTHON3_COMMAND" - "$BEFORE_FILE" "$AFTER_FILE" <<'PY' > "$CHANGES_FILE"
from pathlib import Path
import sys

def read_state(path):
    rows = {}
    for line in Path(path).read_text().splitlines():
        entry_type, name, state, version = line.split('|', 3)
        rows[(entry_type, name)] = {'state': state, 'version': version}
    return rows

before = read_state(sys.argv[1])
after = read_state(sys.argv[2])

for (entry_type, name), after_data in after.items():
    before_data = before[(entry_type, name)]
    if before_data['state'] == 'installed' and after_data['state'] == 'installed' and before_data['version'] != after_data['version']:
        print(f'{name}|Upgraded')
PY

  while IFS='|' read -r entry_name change_name; do
    [[ -n "$entry_name" ]] || continue
    log_change "Installation" "$entry_name" "$change_name" "$BREW_PREFIX" "Managed by Brewfile upgrade"
  done < "$CHANGES_FILE"
}

require_macos
require_command git
require_clean_pushed_repo_state "$ROOT" "brew-upgrade"
require_homebrew
require_clt
require_command cmp
initialize_change_log "scripts/macos/brew-upgrade"
PYTHON3_COMMAND="$(preferred_python3_command)"

ENTRIES_FILE="$(mktemp)"
BEFORE_FILE="$(mktemp)"
AFTER_FILE="$(mktemp)"
CHANGES_FILE="$(mktemp)"
BREW_UPDATE_OUTPUT_FILE="$(mktemp)"
BREW_PREFIX="$(brew --prefix)"

echo "==> Updating Homebrew metadata"
brew update 2>&1 | tee "$BREW_UPDATE_OUTPUT_FILE"

if ! grep -q '^Already up-to-date\.$' "$BREW_UPDATE_OUTPUT_FILE"; then
  log_change "Installation" "Homebrew metadata" "Updated" "$BREW_PREFIX" "Updated Homebrew metadata"
fi

if [[ -n "$BREWFILE_OVERRIDE" ]]; then
  upgrade_brewfile_entries "$BREWFILE_OVERRIDE"
else
  upgrade_brewfile_entries "$(shared_platform_config_path "config/brew" "Brewfile")"

  BREWFILE_OVERRIDE="$(host_platform_config_path "config/brew" "Brewfile")"
  if [[ -f "$BREWFILE_OVERRIDE" ]]; then
    upgrade_brewfile_entries "$BREWFILE_OVERRIDE"
  fi
fi

echo "==> Homebrew and Brewfile entries are up to date"
