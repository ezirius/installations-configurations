#!/usr/bin/env bash
# Shared Homebrew installer.
#
# This script resolves layered Brewfiles from:
# - configs/shared/brew/Brewfile-shared-shared
# - configs/shared/brew/Brewfile-shared-<username>
# - configs/shared/brew/Brewfile-<host>-shared
# - configs/shared/brew/Brewfile-<host>-<username>
# - configs/<os>/brew/Brewfile-shared-shared
# - configs/<os>/brew/Brewfile-shared-<username>
# - configs/<os>/brew/Brewfile-<host>-shared
# - configs/<os>/brew/Brewfile-<host>-<username>
#
# Matching order is least specific to most specific:
# 1. shared.shared
# 2. shared.x
# 3. x.shared
# 4. x.x
# within the shared OS scope, then the concrete OS scope.
#
# It installs only missing entries. Already installed formulae and casks are
# reported and skipped. It does not run `brew update` or upgrade installed
# entries.

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/../../../libs/shared/shared/common.sh"

show_usage() {
  show_help "Usage: $(basename "$0") [-h|--help]

Install missing Homebrew formulae and casks from the matching layered Brewfiles.

Brewfile naming:
  Brewfile-<host>-<username>

Resolution order:
  1. configs/shared/brew/Brewfile-shared-shared
  2. configs/shared/brew/Brewfile-shared-<username>
  3. configs/shared/brew/Brewfile-<host>-shared
  4. configs/shared/brew/Brewfile-<host>-<username>
  5. configs/<os>/brew/Brewfile-shared-shared
  6. configs/<os>/brew/Brewfile-shared-<username>
  7. configs/<os>/brew/Brewfile-<host>-shared
  8. configs/<os>/brew/Brewfile-<host>-<username>

Notes:
  - <host> and <username> each support 'shared'.
  - concrete host and username values are normalised from the current machine.
  - Only missing entries are installed. Installed entries are skipped.
  - This command does not run brew update or upgrade installed entries."
}

require_command() {
  local command_name="$1"

  command -v "$command_name" >/dev/null 2>&1 || fail "Required command is missing: $command_name"
}

NUSHELL_COMPATIBILITY_WARNING=''
PREPARED_NUSHELL_CONFIG_PATH=''

shell_setup_block_begin() {
  printf '%s\n' '# >>> installations-and-configurations homebrew shellenv >>>'
}

shell_setup_block_end() {
  printf '%s\n' '# <<< installations-and-configurations homebrew shellenv <<<'
}

nushell_path_block_begin() {
  printf '%s\n' '# >>> installations-and-configurations homebrew path >>>'
}

nushell_path_block_end() {
  printf '%s\n' '# <<< installations-and-configurations homebrew path <<<'
}

shellenv_block_content() {
  local brew_path="$1"
  local shell_name="$2"

  printf 'eval "$(%s shellenv %s)"\n' "$brew_path" "$shell_name"
}

nushell_path_block_content() {
  local brew_bin_dir="$1"
  local brew_sbin_dir="$2"

  printf '%s\n' \
    "let brew_bin = \"$brew_bin_dir\"" \
    "let brew_sbin = \"$brew_sbin_dir\"" \
    '' \
    'if ($env.PATH | describe | str starts-with "list<") {' \
    '  if $brew_sbin not-in $env.PATH {' \
    '    $env.PATH = ($env.PATH | prepend $brew_sbin)' \
    '  }' \
    '  if $brew_bin not-in $env.PATH {' \
    '    $env.PATH = ($env.PATH | prepend $brew_bin)' \
    '  }' \
    '}'
}

nushell_conflict_message() {
  printf '%s\n' 'Conflicting Nushell config exists in both canonical and macOS compatibility locations. Resolve manually.'
}

resolve_canonical_nushell_dir() {
  if [[ -n "${XDG_CONFIG_HOME:-}" ]]; then
    printf '%s/nushell\n' "$XDG_CONFIG_HOME"
  else
    printf '%s/.config/nushell\n' "$HOME"
  fi
}

resolve_canonical_nushell_config_path() {
  printf '%s/config.nu\n' "$(resolve_canonical_nushell_dir)"
}

macos_nushell_compatibility_dir() {
  printf '%s/Library/Application Support/nushell\n' "$HOME"
}

resolve_symlink_target_path() {
  local link_path="$1"
  local raw_target
  local link_dir

  raw_target="$(command readlink "$link_path")"
  if [[ "$raw_target" == /* ]]; then
    printf '%s\n' "$raw_target"
  else
    link_dir="$(command dirname "$link_path")"
    printf '%s/%s\n' "$link_dir" "$raw_target"
  fi
}

nushell_dirs_conflict() {
  local source_dir="$1"
  local destination_dir="$2"
  local source_path
  local relative_path
  local destination_path

  [[ -d "$source_dir" ]] || return 1

  while IFS= read -r source_path; do
    relative_path="${source_path#"$source_dir"/}"
    destination_path="$destination_dir/$relative_path"

    if [[ -d "$source_path" ]]; then
      if [[ -e "$destination_path" && ! -d "$destination_path" ]]; then
        return 0
      fi
      continue
    fi

    if [[ -e "$destination_path" || -L "$destination_path" ]]; then
      if [[ -d "$destination_path" ]]; then
        return 0
      fi

      if ! cmp -s "$source_path" "$destination_path" 2>/dev/null; then
        return 0
      fi
    fi
  done < <(command find "$source_dir" -mindepth 1)

  return 1
}

migrate_nushell_dir_contents() {
  local source_dir="$1"
  local destination_dir="$2"
  local source_path
  local relative_path
  local destination_path

  [[ -d "$source_dir" ]] || return 0
  command mkdir -p "$destination_dir"

  if nushell_dirs_conflict "$source_dir" "$destination_dir"; then
    fail "$(nushell_conflict_message)"
  fi

  while IFS= read -r source_path; do
    relative_path="${source_path#"$source_dir"/}"
    destination_path="$destination_dir/$relative_path"

    if [[ -d "$source_path" ]]; then
      command mkdir -p "$destination_path"
      continue
    fi

    command mkdir -p "$(command dirname "$destination_path")"
    if [[ -e "$destination_path" || -L "$destination_path" ]]; then
      command rm -f "$source_path"
    else
      command mv "$source_path" "$destination_path"
    fi
  done < <(command find "$source_dir" -mindepth 1 -depth)

  command rm -rf "$source_dir"
}

ensure_macos_nushell_compatibility_symlink() {
  local canonical_dir="$1"
  local compatibility_dir
  local compatibility_parent
  local compatibility_target

  compatibility_dir="$(macos_nushell_compatibility_dir)"
  compatibility_parent="$(command dirname "$compatibility_dir")"
  command mkdir -p "$compatibility_parent"
  command mkdir -p "$canonical_dir"

  if [[ -L "$compatibility_dir" ]]; then
    compatibility_target="$(resolve_symlink_target_path "$compatibility_dir")"
    if [[ "$compatibility_target" == "$canonical_dir" ]]; then
      return 0
    fi

    if [[ -d "$compatibility_target" ]]; then
      migrate_nushell_dir_contents "$compatibility_target" "$canonical_dir"
    elif [[ -e "$compatibility_target" ]]; then
      fail "$(nushell_conflict_message)"
    fi

    command rm "$compatibility_dir"
    command ln -s "$canonical_dir" "$compatibility_dir"
    NUSHELL_COMPATIBILITY_WARNING="WARNING: Corrected Nushell compatibility symlink to point to $canonical_dir"
    return 0
  fi

  if [[ -d "$compatibility_dir" ]]; then
    migrate_nushell_dir_contents "$compatibility_dir" "$canonical_dir"
    command ln -s "$canonical_dir" "$compatibility_dir"
    return 0
  fi

  if [[ -e "$compatibility_dir" ]]; then
    fail "$(nushell_conflict_message)"
  fi

  command ln -s "$canonical_dir" "$compatibility_dir"
}

prepare_nushell_config_path() {
  local os_name="$1"
  local canonical_dir

  canonical_dir="$(resolve_canonical_nushell_dir)"

  if [[ "$os_name" == 'macos' && -z "${XDG_CONFIG_HOME:-}" ]]; then
    ensure_macos_nushell_compatibility_symlink "$canonical_dir"
  else
    command mkdir -p "$canonical_dir"
  fi

  PREPARED_NUSHELL_CONFIG_PATH="$canonical_dir/config.nu"
}

persist_shell_setup() {
  local os_name="$1"
  local brew_path
  local brew_bin_dir
  local brew_prefix
  local brew_sbin_dir
  local zprofile_path
  local bash_profile_path
  local bashrc_path
  local nushell_config_path

  brew_path="$(command -v brew)"
  brew_bin_dir="$(dirname "$brew_path")"
  brew_prefix="$(dirname "$brew_bin_dir")"
  brew_sbin_dir="$brew_prefix/sbin"
  zprofile_path="$HOME/.zprofile"
  bash_profile_path="$HOME/.bash_profile"
  bashrc_path="$HOME/.bashrc"
  prepare_nushell_config_path "$os_name"
  nushell_config_path="$PREPARED_NUSHELL_CONFIG_PATH"

  upsert_managed_block \
    "$zprofile_path" \
    "$(shell_setup_block_begin)" \
    "$(shell_setup_block_end)" \
    "$(shellenv_block_content "$brew_path" 'zsh')"
  upsert_managed_block \
    "$bash_profile_path" \
    "$(shell_setup_block_begin)" \
    "$(shell_setup_block_end)" \
    "$(shellenv_block_content "$brew_path" 'bash')"
  upsert_managed_block \
    "$bashrc_path" \
    "$(shell_setup_block_begin)" \
    "$(shell_setup_block_end)" \
    "$(shellenv_block_content "$brew_path" 'bash')"
  upsert_managed_block \
    "$nushell_config_path" \
    "$(nushell_path_block_begin)" \
    "$(nushell_path_block_end)" \
    "$(nushell_path_block_content "$brew_bin_dir" "$brew_sbin_dir")"

  if [[ -n "$NUSHELL_COMPATIBILITY_WARNING" ]]; then
    print_warning "$NUSHELL_COMPATIBILITY_WARNING" >&2
  fi

  print_green 'Configured shell startup for zsh, bash, and nushell'
}

# Add a Brewfile to the active layer list when it exists, otherwise report the
# missing optional layer as a plain-text skip.
add_candidate_if_present() {
  local candidate_path="$1"

  if [[ -f "$candidate_path" ]]; then
    BREWFILES+=("$candidate_path")
    print_green "Using Brewfile: $candidate_path"
  else
    print_skip "Skipping missing Brewfile: $candidate_path"
  fi
}

# Resolve every matching Brewfile layer from least specific to most specific.
resolve_brewfiles() {
  local root_path="$1"
  local os_name="$2"
  local host_name="$3"
  local user_name="$4"

  # Load every matching layer from least specific to most specific so shared
  # Brewfiles provide the additive baseline before more specific layers.
  BREWFILES=()
  add_candidate_if_present "$root_path/configs/shared/brew/Brewfile-shared-shared"
  add_candidate_if_present "$root_path/configs/shared/brew/Brewfile-shared-$user_name"
  add_candidate_if_present "$root_path/configs/shared/brew/Brewfile-$host_name-shared"
  add_candidate_if_present "$root_path/configs/shared/brew/Brewfile-$host_name-$user_name"
  add_candidate_if_present "$root_path/configs/$os_name/brew/Brewfile-shared-shared"
  add_candidate_if_present "$root_path/configs/$os_name/brew/Brewfile-shared-$user_name"
  add_candidate_if_present "$root_path/configs/$os_name/brew/Brewfile-$host_name-shared"
  add_candidate_if_present "$root_path/configs/$os_name/brew/Brewfile-$host_name-$user_name"

  if [[ ${#BREWFILES[@]} -eq 0 ]]; then
    fail "No matching Brewfiles found for os=$os_name host=$host_name username=$user_name"
  fi
}

# Parse only the supported Brewfile entry forms and fail on any other non-empty
# directive so the active syntax contract stays narrow and explicit.
parse_brewfile_entries() {
  local brewfile_path="$1"
  local line
  local trimmed_line
  local entry_type
  local remainder
  local quote_char
  local entry_name
  local trailing_content

  while IFS= read -r line || [[ -n "$line" ]]; do
    trimmed_line="${line#"${line%%[![:space:]]*}"}"
    [[ -z "$trimmed_line" ]] && continue
    [[ "$trimmed_line" == \#* ]] && continue

    case "$trimmed_line" in
      brew\ *|cask\ *)
        entry_type="${trimmed_line%% *}"
        remainder="${trimmed_line#"$entry_type"}"
        remainder="${remainder#"${remainder%%[![:space:]]*}"}"
        quote_char="${remainder:0:1}"
        if [[ "$quote_char" != '"' ]]; then
          fail "Unsupported Brewfile line in $brewfile_path: $line"
        fi
        entry_name="${remainder#?}"
        [[ "$entry_name" == *"$quote_char"* ]] || fail "Unsupported Brewfile line in $brewfile_path: $line"
        entry_name="${entry_name%%"$quote_char"*}"
        [[ -n "$entry_name" ]] || fail "Unsupported Brewfile line in $brewfile_path: $line"
        trailing_content="${remainder#"$quote_char$entry_name$quote_char"}"
        [[ -z "${trailing_content//[[:space:]]/}" ]] || fail "Unsupported Brewfile line in $brewfile_path: $line"
        printf '%s|%s\n' "$entry_type" "$entry_name"
        ;;
      *)
        fail "Unsupported Brewfile line in $brewfile_path: $line"
        ;;
    esac
  done < "$brewfile_path"
}

# Check whether a managed Brewfile entry is already installed.
entry_is_installed() {
  local entry_type="$1"
  local entry_name="$2"

  if [[ "$entry_type" == "brew" ]]; then
    brew list --versions "$entry_name" >/dev/null 2>&1
  else
    brew list --cask --versions "$entry_name" >/dev/null 2>&1
  fi
}

# Read the installed version string for one Brewfile entry, returning an empty
# value when Homebrew does not report one.
installed_entry_version() {
  local entry_type="$1"
  local entry_name="$2"
  local installed_output
  local version_name

  if [[ "$entry_type" == "brew" ]]; then
    installed_output="$(brew list --versions "$entry_name" 2>/dev/null || true)"
  else
    installed_output="$(brew list --cask --versions "$entry_name" 2>/dev/null || true)"
  fi

  version_name="${installed_output#"$entry_name"}"
  version_name="${version_name#"${version_name%%[![:space:]]*}"}"
  printf '%s\n' "$version_name"
}

# Look up the display name for one configured Local Network warning token.
warning_display_name_for_token() {
  local token_name="$1"
  local mapping
  local mapping_token
  local mapping_display

  IFS=',' read -r -a WARNING_MAPPINGS <<< "$LOCAL_NETWORK_WARNING_ITEMS"
  for mapping in "${WARNING_MAPPINGS[@]}"; do
    mapping_token="${mapping%%:*}"
    mapping_display="${mapping#*:}"
    if [[ "$mapping_token" == "$mapping" || -z "$mapping_display" ]]; then
      fail "Invalid LOCAL_NETWORK_WARNING_ITEMS entry: $mapping"
    fi

    if [[ "$mapping_token" == "$token_name" ]]; then
      printf '%s\n' "$mapping_display"
      return 0
    fi
  done

  return 1
}

# Mark one matched installed token for Local Network warning output once.
mark_local_network_warning_item_if_configured() {
  local token_name="$1"
  local display_name
  local warning_entry

  if ! display_name="$(warning_display_name_for_token "$token_name")"; then
    return 0
  fi

  warning_entry="$token_name|$display_name"
  case $'\n'"$LOCAL_NETWORK_WARNING_MATCHES"$'\n' in
    *$'\n'"$warning_entry"$'\n'*)
      return 0
      ;;
  esac

  if [[ -n "$LOCAL_NETWORK_WARNING_MATCHES" ]]; then
    LOCAL_NETWORK_WARNING_MATCHES+=$'\n'
  fi
  LOCAL_NETWORK_WARNING_MATCHES+="$warning_entry"
}

# Print the config-backed Local Network warning for matched managed items that
# are already installed or were installed by this run.
print_local_network_warning_if_needed() {
  local warning_entry
  local display_name

  [[ -n "$LOCAL_NETWORK_WARNING_MATCHES" ]] || return 0

  print_warning "$LOCAL_NETWORK_WARNING_TITLE"
  while IFS= read -r warning_entry || [[ -n "$warning_entry" ]]; do
    [[ -n "$warning_entry" ]] || continue
    display_name="${warning_entry#*|}"
    print_warning "Enable Local Network access for: $display_name"
  done <<< "$LOCAL_NETWORK_WARNING_MATCHES"
}

# Read the current Homebrew version token, returning an empty value when it
# cannot be resolved.
homebrew_version() {
  local version_output
  local first_line

  version_output="$(brew --version 2>/dev/null || true)"
  first_line="${version_output%%$'\n'*}"
  first_line="${first_line#Homebrew }"

  if [[ "$first_line" == "$version_output" && "$version_output" != Homebrew* ]]; then
    printf '\n'
    return 0
  fi

  printf '%s\n' "$first_line"
}

homebrew_bootstrap_is_interactive() {
  case "${TEST_FORCE_INTERACTIVE:-}" in
    1)
      return 0
      ;;
    0)
      return 1
      ;;
  esac

  [[ -t 0 && -t 1 ]]
}

# Install Homebrew when it is missing, then log the bootstrap install.
bootstrap_homebrew_if_missing() {
  local version_name

  if command -v brew >/dev/null 2>&1; then
    return 0
  fi

  require_command curl
  print_warning 'WARNING: Homebrew is missing; installing Homebrew'

  if homebrew_bootstrap_is_interactive; then
    /bin/bash -c "$(curl -fsSL "$HOMEBREW_INSTALL_URL")"
  elif ! NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL "$HOMEBREW_INSTALL_URL")"; then
    fail 'Homebrew bootstrap requires sudo, but this run is non-interactive and cannot prompt for a password. Install Homebrew first or rerun from an interactive terminal.'
  fi

  load_homebrew_shellenv
  command -v brew >/dev/null 2>&1 || fail 'Homebrew installation did not provide brew'

  version_name="$(homebrew_version)"
  append_activity_log_row "$LOG_FILE_PATH" "$LOG_HOST_NAME" "$ACTION_INSTALLED" 'brew' "$version_name"
  print_green 'Installed brew'
}

# Install one Brewfile entry only when it is currently missing.
install_missing_entry() {
  local entry_type="$1"
  local entry_name="$2"
  local version_name

  if entry_is_installed "$entry_type" "$entry_name"; then
    mark_local_network_warning_item_if_configured "$entry_name"
    print_skip "Skipping installed $entry_type: $entry_name"
    return 0
  fi

  if [[ "$entry_type" == "brew" ]]; then
    brew install "$entry_name"
  else
    brew install --cask "$entry_name"
  fi

  version_name="$(installed_entry_version "$entry_type" "$entry_name")"
  append_activity_log_row "$LOG_FILE_PATH" "$LOG_HOST_NAME" "$ACTION_INSTALLED" "$entry_name" "$version_name"
  mark_local_network_warning_item_if_configured "$entry_name"
  print_green "Installed $entry_type: $entry_name"
}

# Process one Brewfile completely before moving to the next layer.
process_brewfile() {
  local brewfile_path="$1"
  local entries_file
  local entry_type
  local entry_name
  local status

  entries_file="$(mktemp)"
  if (parse_brewfile_entries "$brewfile_path" > "$entries_file"); then
    :
  else
    status=$?
    rm -f "$entries_file"
    return "$status"
  fi

  if exec 3< "$entries_file"; then
    :
  else
    status=$?
    rm -f "$entries_file"
    return "$status"
  fi

  if while IFS='|' read -r entry_type entry_name <&3; do
    [[ -n "$entry_name" ]] || continue
    install_missing_entry "$entry_type" "$entry_name"
  done; then
    exec 3<&-
    rm -f "$entries_file"
  else
    status=$?
    exec 3<&-
    rm -f "$entries_file"
    return "$status"
  fi
}

# Entrypoint for the active shared Homebrew install workflow.
main() {
  local root_path
  local os_name
  local host_name
  local user_name
  local brewfile_path
  local version_name

  if is_help_flag "${1-}"; then
    show_usage
  fi

  if [[ $# -ne 0 ]]; then
    fail "brew-install takes no arguments. Use --help for usage."
  fi

  root_path="$(repo_root_from_script_path "$SCRIPT_PATH")"
  load_shared_logging_config "$root_path"
  clear_config_values \
    'HOMEBREW_INSTALL_URL' \
    'LOCAL_NETWORK_WARNING_TITLE' \
    'LOCAL_NETWORK_WARNING_ITEMS'
  load_required_config "$root_path" 'configs/shared/brew/brew-install.conf'
  require_config_value 'HOMEBREW_INSTALL_URL'
  require_config_value 'LOCAL_NETWORK_WARNING_TITLE'
  require_config_value 'LOCAL_NETWORK_WARNING_ITEMS'
  os_name="$(detect_os)"
  host_name="$(detect_host)"
  user_name="$(detect_username)"
  BREWFILES=()
  LOCAL_NETWORK_WARNING_MATCHES=''
  LOG_HOST_NAME="$host_name"
  LOG_FILE_PATH="$(activity_log_file_path "$root_path" "$os_name" "$host_name")"

  print_green "Context: os=$os_name host=$host_name username=$user_name"

  load_homebrew_shellenv
  bootstrap_homebrew_if_missing
  command -v brew >/dev/null 2>&1 || fail 'Homebrew is not installed'

  print_green 'Homebrew found'
  version_name="$(homebrew_version)"
  [[ -n "$version_name" ]] && printf 'Homebrew %s\n' "$version_name"
  persist_shell_setup "$os_name"

  resolve_brewfiles "$root_path" "$os_name" "$host_name" "$user_name"

  for brewfile_path in "${BREWFILES[@]}"; do
    process_brewfile "$brewfile_path"
  done

  print_local_network_warning_if_needed
  print_green 'Done'
}

main "$@"
