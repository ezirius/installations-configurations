#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/../../../lib/shell/shared/common.sh"

load_brew_workflow_config() {
  source_layered_scoped_config "config/brew" "macos" "brew-settings" "conf"
}

validate_brew_workflow_config() {
  [[ -n "${BREW_BOOTSTRAP_STEPS+set}" ]] || fail "BREW_BOOTSTRAP_STEPS is not set in the managed Brew workflow config"
  [[ -n "${BREW_BOOTSTRAP_SERVICE_ACTION-}" ]] || fail "BREW_BOOTSTRAP_SERVICE_ACTION is not set in the managed Brew workflow config"
}

format_brew_array_lines() {
  local line_prefix="$1"
  shift
  local item

  for item in "$@"; do
    printf '%s%s\n' "$line_prefix" "$item"
  done
}

if is_help_flag "${1-}"; then
  load_brew_workflow_config
  show_help "Usage: $(basename "$0")

Run the full managed macOS Brew workflow defined in config.

Configured bootstrap steps:
$(format_brew_array_lines '  - ' "${BREW_BOOTSTRAP_STEPS[@]}")
  - brew-service $BREW_BOOTSTRAP_SERVICE_ACTION"
fi

if [[ $# -ne 0 ]]; then
  usage_error "$(basename "$0") takes no arguments"
fi

require_macos
load_brew_workflow_config
validate_brew_workflow_config

echo "==> Running macOS brew bootstrap"
for step in "${BREW_BOOTSTRAP_STEPS[@]}"; do
  "$(resolve_brew_workflow_script_path "$step")"
done
"$(resolve_brew_workflow_script_path "brew-service")" "$BREW_BOOTSTRAP_SERVICE_ACTION"

echo "==> macOS brew bootstrap is complete"
